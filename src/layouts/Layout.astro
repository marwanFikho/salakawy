---
import { ClientRouter } from 'astro:transitions';
import { Image } from 'astro:assets';
import logo from '../assets/salakawy-logo.png';
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';
import WhatsappFloatingButton from '../components/WhatsappFloatingButton.astro';
import SocialProof from '../components/SocialProof.astro';
import AggressiveConversion from '../components/AggressiveConversion.astro';
import VisualBuilder from '../components/VisualBuilder.astro';

export interface Props {
	title: string;
}

const { title } = Astro.props;

import { getContent, getVal } from '../backend/content';
const c = getContent('layout');
const defaultMarquee = [
    "🔥 NO EXCUSES", "💪 GUARANTEED RESULTS", "🔥 STOP PROCRASTINATING", 
    "🏆 OVER 11000+ TRANSFORMED", "🚀 YOU ARE NEXT", "⚡ CLAIM YOUR BODY TODAY"
];
const marqueeItems = getVal(c, 'marquee', defaultMarquee);
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/salakawy-logo.png" />
		<meta name="generator" content={Astro.generator} />
		<!-- Open Graph & SEO -->
		<meta name="description" content="I don't sell a simple diet plan or workout routine. I sell a mindset and lifestyle you can follow for life. Salakawy." />
		<title>{title}</title>
		
		<!-- Progressive Web App (PWA) / Mobile Optimizations -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#0d0e12" />
		<meta name="color-scheme" content="dark" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Salakawy" />
		<meta name="mobile-web-app-capable" content="yes" />
		
		<ClientRouter />

		<!-- Google Fonts: Outfit for a modern elegant look -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
	</head>
	<body>

		<!-- Preloader -->
		<div id="preloader" class="preloader">
            <!-- The dark screen that becomes a logo-shaped hole -->
            <div class="preloader-overlay"></div>
            
            <div class="preloader-logo-wrapper">
                <img src="/salakawy-logo-trace.svg" class="perimeter-light-svg" alt="" />
                <img src="/salakawy-logo.svg" alt="Salakawy" class="preloader-logo" />
            </div>
		</div>

		<!-- Top Marquee Banner -->
		<div class="marquee-container">
			<div class="marquee-content" aria-hidden="true">
				{marqueeItems.map((text, i) => (
					<span class="marquee-text" data-editable={`layout:marquee.${i}`} set:html={text} />
				))}
				<!-- duplicate for seamless loop -->
				{marqueeItems.map((text) => (
					<span class="marquee-text" set:html={text} />
				))}
			</div>
		</div>

		<!-- Header / Nav -->
		<header class="navbar">
			<div class="container nav-content">
				<a href="/" class="logo">
					<img src="/salakawy-logo.png" alt="Salakawy Gym Coach Logo" height="40" width="auto" />
				</a>
				
                <!-- Desktop Nav -->
                <nav class="nav-links">
					<a href="/#hero">Home</a>
					<a href="/#transformations">Transformations</a>
					<a href="/common-challenges">Challenges</a>
					<a href="/resources">Resources</a>
					<a href="/#packages">Packages</a>
				</nav>

                <!-- Mobile Hamburger Toggle -->
                <button class="hamburger" id="hamburger-btn" aria-label="Toggle Menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
			</div>
		</header>

        <!-- Mobile Overlay Menu -->
        <nav class="mobile-menu" id="mobile-menu">
            <div class="mobile-menu-content">
                <a href="/#hero" class="mobile-link">Home</a>
                <a href="/#transformations" class="mobile-link">Transformations</a>
                <a href="/common-challenges" class="mobile-link">Challenges</a>
                <a href="/resources" class="mobile-link">Resources</a>
                <a href="/#packages" class="mobile-link">Packages</a>
            </div>
        </nav>

		<slot />

		<footer class="footer">
			<div class="container footer-grid">
                <div class="footer-col brand-col">
                    <a href="/" class="footer-logo-link">
                        <img src="/salakawy-logo.png" alt="Salakawy" class="footer-logo" height="80" width="auto" />
                    </a>
                    <p class="brand-desc" data-editable="layout:footer.desc" set:html={getVal(c, 'footer.desc', 'Not Just a Transformation. <br/> <strong>A Mindset for Life.</strong>')} />
                </div>

                <div class="footer-col links-col">
                    <h3 data-editable="layout:footer.l1" set:html={getVal(c, 'footer.l1', 'Quick Links')} />
                    <ul>
                        <li><a href="/#hero">Home</a></li>
                        <li><a href="/#transformations">Transformations</a></li>
                        <li><a href="/common-challenges">Challenges</a></li>
                        <li><a href="/resources">Resources</a></li>
                        <li><a href="/#packages">Packages</a></li>
                    </ul>
                </div>

                <div class="footer-col contact-col">
                    <h3 data-editable="layout:footer.l2" set:html={getVal(c, 'footer.l2', 'Connect With Me')} />
                    <div class="social-links">
                        <a href="https://www.instagram.com/salakawy7" target="_blank" rel="noopener" class="social-icon" aria-label="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                        </a>
                        <a href="https://www.facebook.com/profile.php?id=61551820782943" target="_blank" rel="noopener" class="social-icon" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                        </a>
                        <a href="https://www.tiktok.com/@salakawy7_" target="_blank" rel="noopener" class="social-icon" aria-label="TikTok">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
                        </a>
                    </div>
                </div>
			</div>
            <div class="footer-bottom">
                <p>&copy; {new Date().getFullYear()} Salakawy. All rights reserved.</p>
                <p class="creator-credit">Made with 💛 by <a href="https://linktr.ee/marwanfikho" target="_blank" rel="noopener">Marwan El-Fakharany</a></p>
            </div>
		</footer>

        <!-- Scroll To Top Button -->
        <button id="scrollToTopBtn" class="scroll-top-btn" aria-label="Scroll to top">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
        </button>

		<style>
			.navbar {
				position: fixed;
				top: 44px; /* Offset to sit exactly below the top marquee */
				width: 100%;
				background: rgba(13, 14, 18, 0.85);
				backdrop-filter: blur(15px);
				-webkit-backdrop-filter: blur(15px);
				z-index: 1000;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				transition: top 0s linear; /* Instant so it moves seamlessly with scroll */
			}

			.nav-content {
				display: flex;
				justify-content: space-between;
				align-items: center;
				height: 60px;
			}

			.logo img {
				height: 40px;
				width: auto;
				display: block;
				transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.logo:hover img {
				transform: scale(1.05);
			}

			.nav-links {
				display: flex;
				gap: 1.5rem;
			}

			.nav-links a {
				font-weight: 600;
				font-size: 1.05rem;
				color: var(--text-muted);
			}

			.nav-links a:hover {
				color: var(--text-main);
			}

            /* Hamburger Menu Styles */
            .hamburger {
                display: none;
                flex-direction: column;
                justify-content: space-between;
                width: 30px;
                height: 20px;
                background: transparent;
                border: none;
                cursor: pointer;
                z-index: 1001; /* Above mobile menu overlay */
            }

            .hamburger span {
                height: 3px;
                width: 100%;
                background-color: var(--text-main);
                border-radius: 3px;
                transition: all 0.3s ease;
            }

            .hamburger.active span:nth-child(1) {
                transform: translateY(8px) rotate(45deg);
            }

            .hamburger.active span:nth-child(2) {
                opacity: 0;
            }

            .hamburger.active span:nth-child(3) {
                transform: translateY(-9px) rotate(-45deg);
            }

            /* Mobile Menu Overlay */
            .mobile-menu {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100vh;
                background: rgba(10, 10, 10, 0.98);
                backdrop-filter: blur(20px);
                z-index: 999;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.4s ease;
            }

            .mobile-menu.active {
                opacity: 1;
                pointer-events: all;
            }

            .mobile-menu-content {
                display: flex;
                flex-direction: column;
                gap: 2rem;
                text-align: center;
            }

            .mobile-link {
                font-size: 2rem;
                font-weight: 700;
                color: var(--text-muted);
                transition: color 0.3s ease;
            }

            .mobile-link:hover, .mobile-link:active {
                color: var(--accent-color);
            }

            /* Footer Styles */
			.footer {
				background-color: #050505;
				padding: 6rem 0 0;
				border-top: 1px solid rgba(255, 255, 0, 0.05);
			}
			
            .footer-grid {
                display: grid;
                grid-template-columns: 1.5fr 1fr 1fr;
                gap: 4rem;
                padding-bottom: 4rem;
            }

            .footer-col h3 {
                font-size: 1.2rem;
                color: #fff;
                margin-bottom: 1.5rem;
            }

            .footer-logo {
                height: 100px;
                width: auto;
                margin-bottom: 1.5rem;
                filter: drop-shadow(0 0 10px rgba(255, 255, 0, 0.1));
                transition: transform 0.3s ease;
            }

            .footer-logo-link:hover .footer-logo {
                transform: scale(1.05);
            }

            .brand-desc {
                color: var(--text-muted);
                line-height: 1.6;
                font-size: 0.95rem;
                max-width: 400px;
            }

            .links-col ul {
                list-style: none;
                padding: 0;
            }

            .links-col li {
                margin-bottom: 0.8rem;
            }

            .links-col a {
                color: var(--text-muted);
                transition: color var(--transition);
            }

            .links-col a:hover {
                color: var(--accent-color);
            }

			.social-links {
				display: flex;
				gap: 1rem;
			}

			.social-icon {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 40px;
                height: 40px;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
				color: var(--text-main);
				font-weight: 600;
                font-size: 0.9rem;
                transition: all var(--transition);
			}

            .social-icon:hover {
                background: var(--accent-color);
                color: #000;
                transform: translateY(-3px);
            }

            .footer-bottom {
                text-align: center;
                padding: 2rem 0;
                border-top: 1px solid rgba(255,255,255,0.05);
                font-size: 0.9rem;
                color: var(--text-muted);
                letter-spacing: 0.5px;
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }

            .creator-credit {
                font-size: 0.85rem;
                opacity: 0.8;
            }

            .creator-credit a {
                color: var(--accent-color);
                text-decoration: none;
                font-weight: 600;
                transition: opacity 0.2s;
            }

            .creator-credit a:hover {
                opacity: 0.7;
                text-decoration: underline;
            }

            /* Scroll to Top */
            .scroll-top-btn {
                position: fixed;
                bottom: 105px; /* Moved up to avoid overlap with WhatsApp button (30px + 60px + 15px gap) */
                right: 30px;
                width: 54px;
                height: 54px;
                border-radius: 50%;
                background: rgba(255, 255, 0, 0.1);
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                color: var(--accent-color);
                border: 2px solid var(--accent-color);
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0;
                pointer-events: none;
                transform: translateY(20px);
                transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 99;
                box-shadow: 0 0 20px rgba(255, 255, 0, 0.15);
            }

            .scroll-top-btn svg {
                transition: transform 0.3s ease;
            }

            .scroll-top-btn.visible {
                opacity: 1;
                pointer-events: all;
                transform: translateY(0);
            }

            .scroll-top-btn:hover {
                background: var(--accent-color);
                color: #000;
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(255, 255, 0, 0.4);
            }

            .scroll-top-btn:hover svg {
                transform: translateY(-2px);
            }

            /* Responsive */
			@media (max-width: 900px) {
                .footer-grid {
                    grid-template-columns: 1fr;
                    gap: 2.5rem;
                }
            }

			@media (max-width: 768px) {
				.nav-links {
					display: none;
				}
                .hamburger {
                    display: flex;
                }
                .scroll-top-btn {
                    bottom: 85px; /* Adjusted for mobile (20px + 50px + 15px gap) */
                    right: 20px;
                    width: 45px;
                    height: 45px;
                }
			}

            /* Marquee Styles */
            .marquee-container {
                position: absolute; /* Changed from fixed to absolute so it scrolls away */
                top: 0;
                left: 0;
                width: 100%;
                background: var(--accent-color);
                overflow: hidden;
                white-space: nowrap;
                padding: 12px 0;
                z-index: 1000;
                display: flex;
                align-items: center;
                height: 44px;
            }
            .marquee-content {
                display: inline-block;
                animation: marquee-scroll 18s linear infinite;
            }
            .marquee-text {
                font-size: 1.15rem;
                font-weight: 800;
                color: #000;
                margin: 0 20px;
                letter-spacing: 0.5px;
            }
            @keyframes marquee-scroll {
                0% { transform: translateX(0); }
                100% { transform: translateX(-50%); }
            }

            /* Preloader Styles */
            .preloader {
                position: fixed;
                inset: 0;
                z-index: 9999;
                display: flex;
                align-items: center;
                justify-content: center;
                pointer-events: all;
            }

            .preloader.loaded {
                pointer-events: none;
            }

            .preloader-overlay {
                position: absolute;
                inset: 0;
                background: #0d0e12;
                -webkit-mask-image: url('/salakawy-logo.png'), linear-gradient(#fff, #fff);
                mask-image: url('/salakawy-logo.png'), linear-gradient(#fff, #fff);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
                -webkit-mask-position: center, center;
                mask-position: center, center;
                -webkit-mask-repeat: no-repeat, no-repeat;
                mask-repeat: no-repeat, no-repeat;
                /* Hide the hole until loaded to keep background solid */
                -webkit-mask-size: 0px 0px, 100% 100%;
                mask-size: 0px 0px, 100% 100%;
                will-change: mask-size, -webkit-mask-size, opacity; /* performance optimization */
                transform: translateZ(0);
            }

            .preloader-logo-wrapper {
                position: absolute;
                height: 150px;
                display: flex;
                align-items: center;
                justify-content: center;
                will-change: transform, opacity;
                transform: translateZ(0);
            }

            .perimeter-light-svg {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: contain;
                z-index: 3; /* Sits above the inner logo to show the white stroke */
                filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.9)); /* High visibility glow */
            }

            .preloader-logo {
                position: relative;
                height: 100%;
                width: auto;
                object-fit: contain;
                z-index: 2;
                transform: translateZ(0); 
            }

            /* Reveal Animation */
            .preloader.loaded .preloader-logo-wrapper {
                opacity: 0;
                transition: opacity 0.2s ease-out;
            }

            .preloader.loaded .preloader-overlay {
                animation: portal-zoom-out 1.2s forwards cubic-bezier(0.7, 0, 0.2, 1);
            }

            @keyframes portal-zoom-out {
                0% {
                    -webkit-mask-size: 150px auto, 100% 100%;
                    mask-size: 150px auto, 100% 100%;
                    opacity: 1;
                }
                15% {
                    -webkit-mask-size: 140px auto, 100% 100%;
                    mask-size: 140px auto, 100% 100%;
                    opacity: 1;
                }
                100% {
                    -webkit-mask-size: 5000px auto, 100% 100%;
                    mask-size: 5000px auto, 100% 100%;
                    opacity: 0;
                }
            }
		</style>

        <script>
            // Handle Preloader Logic
            function initPreloader() {
                const preloader = document.getElementById('preloader');
                if (!preloader) return;

                if (!preloader.classList.contains('loaded')) {
                    document.body.style.overflow = 'hidden';
                }

                // Hide preloader once resources are ready
                // Using a slight delay for a smoother effect
                const triggerHide = () => {
                    setTimeout(() => {
                        preloader.classList.add('loaded');
                        document.body.style.overflow = '';
                    }, 500);
                };

                // Check if page session is brand new (window load) or navigation (astro:page-load)
                if (document.readyState === 'complete') {
                    triggerHide();
                } else {
                    window.addEventListener('load', triggerHide);
                }
            }

            // Run on Every Load (Initial and Navigation)
            document.addEventListener('astro:page-load', () => {
                // Initialize Preloader
                initPreloader();

                // Mobile Menu Logic
                const hamburger = document.getElementById('hamburger-btn');
                const mobileMenu = document.getElementById('mobile-menu');
                const mobileLinks = document.querySelectorAll('.mobile-link');
                
                if (hamburger && mobileMenu) {
                    // Reset menu state on new page load
                    hamburger.classList.remove('active');
                    mobileMenu.classList.remove('active');
                    document.body.style.overflow = '';

                    hamburger.addEventListener('click', () => {
                        hamburger.classList.toggle('active');
                        mobileMenu.classList.toggle('active');
                        document.body.style.overflow = mobileMenu.classList.contains('active') ? 'hidden' : '';
                    });

                    mobileLinks.forEach(link => {
                        link.addEventListener('click', () => {
                            hamburger.classList.remove('active');
                            mobileMenu.classList.remove('active');
                            document.body.style.overflow = '';
                        });
                    });
                }

                // Scroll To Top Logic
                const scrollBtn = document.getElementById('scrollToTopBtn');
                if (scrollBtn) {
                    window.addEventListener('scroll', () => {
                        if (window.scrollY > 500) {
                            scrollBtn.classList.add('visible');
                        } else {
                            scrollBtn.classList.remove('visible');
                        }
                    });

                    scrollBtn.addEventListener('click', () => {
                        window.scrollTo({
                            top: 0,
                            behavior: 'smooth'
                        });
                    });
                }

                // Sticky Navbar Logic
                const navbar = document.querySelector('.navbar');
                if (navbar) {
                    const handleScroll = () => {
                        if (window.scrollY > 44) {
                            navbar.style.top = '0px';
                        } else {
                            navbar.style.top = (44 - window.scrollY) + 'px';
                        }
                    };
                    window.addEventListener('scroll', handleScroll, { passive: true });
                    handleScroll(); // init on load
                }
            });
        </script>
		<WhatsappFloatingButton />
		<Chatbot />
        <SocialProof />
        <AggressiveConversion />
        <script>
        (function(){
            if(window.location.pathname.startsWith('/admin'))return;
            const sid=Math.random().toString(36).slice(2)+'_'+Date.now();
            const start=Date.now();
            const isMobile=/Mobi|Android/i.test(navigator.userAgent);
            fetch('/api/admin/track',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
                page_url:window.location.pathname,
                referrer:document.referrer||null,
                device_type:isMobile?'mobile':'desktop',
                session_id:sid
            })}).catch(()=>{});
            function sendDuration(){
                const dur=Math.round((Date.now()-start)/1000);
                navigator.sendBeacon&&navigator.sendBeacon('/api/admin/track',new Blob([JSON.stringify({session_id:sid,duration_seconds:dur})],{type:'application/json'}));
            }
            window.addEventListener('beforeunload',sendDuration);
            document.addEventListener('visibilitychange',()=>{if(document.visibilityState==='hidden')sendDuration();});
        })();
        </script>
        <VisualBuilder />
	</body>
</html>
