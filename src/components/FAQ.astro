---
const faqs = [
	{
		q: "What happens after I subscribe to your program?",
		a: "1. Personalized Plan Creation: You’ll receive a detailed questionnaire so we can craft the exact roadmap to **force your success**, without sacrificing your favorite foods.\n2. Tailored to Your Life: Your plan will be customized to fit your schedule, so you can **start acting today**.\n3. Quick Turnaround: Once you complete the payment, your customized plan will be ready within 4-5 days so you can **take control now**."
	},
	{
		q: "What does the program include?",
		a: "1. Flexible Diet Plan: Adjusted to your needs, preferences, and BMR, focusing on your favorite foods.\n2. Daily Check-ins & Updates: Stay motivated with daily support.\n3. WhatsApp Q&A: Got questions? I’m here for you anytime.\n4. Supplement Recommendations (optional): Provided only if you’re interested.\n5. Cardio & Abs Routines: To help you tone up and shed fat.\n6. Gym & Home Workouts: Includes videos to ensure perfect form.\n7. Direct Access to Me: You’ll have my personal number for any support."
	},
	{
		q: "What are the available package options?",
		a: "We offer 4 levels of support to fit every need and budget:\n\n💎 **Platinum Package**: The ultimate VIP experience. I reach out to YOU proactively every day for weight & mindset checks. Maximum support.\n\n👑 **Gold Package**: Daily check-ins and direct phone access. You can call or message me anytime for instant support.\n\n🌟 **Silver Package**: Weekly check-ins directly with me via WhatsApp to keep you on track.\n\n👤 **Support Team**: Weekly follow-ups handled by my assistant team (plans are still designed by me).\n\nAll tiers include the same high-quality personalized diet and workout programs!"
	},
	{
		q: "Refund Policy?",
		a: "• **1-Month Package**:\n- If the plan has been sent: **No refunds available**.\n- If the plan has NOT been sent yet: You receive a **75% refund**.\n\n• **3-Month Package**:\n- Cancel within the first 30 days: The equivalent price of 1 month of the same package is deducted, and the rest is refunded.\n- Cancel within 30-60 days: The equivalent price of 2 months of the same package is deducted, and the rest is refunded.\n- After 60 days: **No refunds are sent** for any 3-month package."
	}
];
---

<section id="faqs" class="section faq-bg">
	<div class="container">
		<div class="faq-header fade-in-up" style="display: flex; flex-direction: column; align-items: center; gap: 1rem;">
			<h2 class="section-title" style="margin-bottom: 0;">All You Need To Know</h2>
			<span class="badge" style="margin-bottom: 0;">FAQs</span>
		</div>

		<div class="faq-list fade-in-up delay-200">
			{faqs.map((faq, index) => (
				<div class="faq-item">
					<button class="faq-question">
						{faq.q}
						<span class="icon">+</span>
					</button>
					<div class="faq-answer-wrapper">
						<div class="faq-answer-inner">
							<div class="faq-answer-content">
								{faq.a.split('\n').map((line) => (
									<p set:html={line.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
								))}
							</div>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	// Client side script to handle the accordion logic
	const faqQuestions = document.querySelectorAll('.faq-question');
	faqQuestions.forEach(question => {
		question.addEventListener('click', () => {
			const item = question.parentElement;
			const wasOpen = item.classList.contains('active');
			
			// Close all other items (Accordion effect)
			document.querySelectorAll('.faq-item').forEach(el => {
				el.classList.remove('active');
			});

			if (!wasOpen) {
				item.classList.add('active');
			}
		});
	});
</script>

<style>
	.faq-bg {
		background-color: var(--surface-color);
	}

	.faq-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	.faq-list {
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.faq-item {
		background: var(--bg-color);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 8px;
		overflow: hidden;
		transition: all var(--transition);
	}

	.faq-item:hover {
		border-color: rgba(255, 255, 0, 0.2);
	}

	.faq-question {
		padding: 1.5rem;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-main);
		display: flex;
		justify-content: space-between;
		align-items: center;
		cursor: pointer;
		background: none;
		border: none;
		width: 100%;
		text-align: left;
		font-family: inherit;
		outline: none;
	}

	.faq-question .icon {
		font-size: 1.5rem;
		color: var(--accent-color);
		font-weight: 400;
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.faq-item.active .faq-question .icon {
		transform: rotate(45deg);
	}

	/* Beautiful Grid-Based height transition for smooth sliding panels */
	.faq-answer-wrapper {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.faq-item.active .faq-answer-wrapper {
		grid-template-rows: 1fr;
	}

	.faq-answer-inner {
		overflow: hidden;
	}

	.faq-answer-content {
		padding: 0 1.5rem 1.5rem;
		color: var(--text-muted);
		line-height: 1.7;
	}
	
	/* The text pop-up fading effect kept gracefully! */
	.faq-item.active .faq-answer-content {
		animation: expandFaqText 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}

	@keyframes expandFaqText {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.faq-answer-content p {
		margin-bottom: 0.5rem;
	}

	.faq-answer-content p:last-child {
		margin-bottom: 0;
	}
</style>
