				</div>
				<div class="package-body">
					<ul class="package-features">
						<li><span class="icon">📅</span> <span data-editable="packages_page:gold.f1" set:html={getVal(c, 'gold.f1', 'Daily responses and updates with Salakawy directly to keep you on track and motivated. ⏰')} /></li>
						<li><span class="icon">💬</span> <span data-editable="packages_page:gold.f2" set:html={getVal(c, 'gold.f2', 'Q & A via whatsapp.')} /></li>
						<li><span class="icon">🍏</span> <span data-editable="packages_page:gold.f3" set:html={getVal(c, 'gold.f3', 'Adjusted Flexible Diet')} /></li>
