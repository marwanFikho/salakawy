							<span class="old-price scratch-graffiti" data-editable="packages_page:gold.p2_old" set:html={getVal(c, 'gold.p2_old', '8200EGP')} />
						</div>
					</div>
					<a href="/contact-us" class="btn btn-primary package-btn mt-auto" data-editable="packages_page:gold.btn" set:html={getVal(c, 'gold.btn', 'Shop Now')} />
				</div>
			</div>

			<!-- Platinum Package -->
			<div class="package-card glass-panel platinum" id="platinum-card">
				<div class="package-header platinum-header">
                    <!-- Diamond sparkle canvas in the background -->
                    <canvas id="plat-canvas" class="plat-canvas"></canvas>

                    <!-- Logo with metallic SVG overlay -->
                    <div class="plat-logo-wrap" id="plat-logo-wrap">
                        <svg class="platinum-svg" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                            <defs>
                                <filter id="plat-glow">
                                    <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
                                    <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                                </filter>
                                <linearGradient id="metallic-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#c0c0c0"/>
                                    <stop offset="30%" stop-color="#ffffff"/>
                                    <stop offset="60%" stop-color="#909090"/>
                                    <stop offset="100%" stop-color="#e0e0e0"/>
                                </linearGradient>
                                <linearGradient id="shine-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="white" stop-opacity="0"/>
                                    <stop offset="50%" stop-color="white" stop-opacity="0.9"/>
                                    <stop offset="100%" stop-color="white" stop-opacity="0"/>
                                </linearGradient>
                                <mask id="logo-mask">
                                    <image href="/salakawy-logo.png" x="0" y="0" width="120" height="120"/>
                                </mask>
                                <clipPath id="logo-clip">
                                    <image href="/salakawy-logo.png" x="0" y="0" width="120" height="120"/>
                                </clipPath>
                            </defs>
                            <!-- Metallic base fill masked to logo shape -->
                            <rect x="0" y="0" width="120" height="120" fill="url(#metallic-grad)" mask="url(#logo-mask)" filter="url(#plat-glow)"/>
                            <!-- Shine beam: Angled gradient for a sharp, non-distorted glare -->
                            <rect id="plat-shine" x="-120" y="0" width="100" height="120" fill="url(#shine-grad)" mask="url(#logo-mask)"/>
                        </svg>
                    </div>

					<h3 data-editable="packages_page:plat.title" set:html={getVal(c, 'plat.title', 'Platinum')} />
