						<li><span class="icon">☎️</span> <span data-editable="packages_page:plat.f8" set:html={getVal(c, 'plat.f8', 'You Have My Phone Number Feel Free to Call Me Anytime')} /></li>
					</ul>
					<div class="pricing-list">
						<div class="pricing-row">
							<span class="duration" data-editable="packages_page:plat.p1_dur" set:html={getVal(c, 'plat.p1_dur', '3 Months:')} />
							<span class="current-price" data-editable="packages_page:plat.p1_cur" set:html={getVal(c, 'plat.p1_cur', '29700EGP/590$')} />
							<span class="old-price scratch-graffiti" data-editable="packages_page:plat.p1_old" set:html={getVal(c, 'plat.p1_old', '43700EGP')} />
						</div>
						<div class="pricing-row">
							<span class="duration" data-editable="packages_page:plat.p2_dur" set:html={getVal(c, 'plat.p2_dur', '1 Month:')} />
							<span class="current-price" data-editable="packages_page:plat.p2_cur" set:html={getVal(c, 'plat.p2_cur', '12700EGP/230$')} />
							<span class="old-price scratch-graffiti" data-editable="packages_page:plat.p2_old" set:html={getVal(c, 'plat.p2_old', '19900EGP')} />
						</div>
					</div>
					<a href="/contact-us" class="btn btn-outline package-btn mt-auto" style="border-color: var(--text-main);" data-editable="packages_page:plat.btn" set:html={getVal(c, 'plat.btn', 'Shop Now')} />
				</div>
			</div>
		</div>

        <!-- Support Package (Horizontal) -->
        <div class="support-package-wrapper fade-in-up delay-300">
            <div class="package-card glass-panel support-horizontal">
                <div class="support-content-flex">
                    <div class="support-left">
                        <div class="package-logo-container standard-logo">
                            <img src="/salakawy-logo.png" alt="Support" class="package-logo" />
