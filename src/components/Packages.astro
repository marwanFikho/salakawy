---
import { Image } from 'astro:assets';
import logo from '../assets/salakawy-logo.png';
---
<section id="packages" class="section packages-bg">
	<div class="container">
		<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 4rem;">
			<h2 class="section-title fade-in-up" style="margin-bottom: 0;">Start Your Journey</h2>
			<span class="badge fade-in-up" style="margin-bottom: 0;">Pricing Plans</span>
			<p class="packages-desc fade-in-up delay-100" style="margin-top: 0;">Choose the package that works best for you. Whether you need a daily roadmap to <strong>force your success</strong> or weekly updates, you must <strong>make a decision today</strong> to <strong>guarantee your transformation</strong>.</p>
		</div>
		
		<div class="packages-grid fade-in-up delay-200">
			<!-- Support Team Package -->
			<div class="package-card glass-panel standard">
				<div class="package-header">
                    <div class="package-logo-container standard-logo">
                        <img src="/salakawy-logo.png" alt="Standard" class="package-logo" />
                    </div>
					<h3>Support Team</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">1200<small>EGP</small></span>
						<span class="price-duration">1 Month (or $45)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">Weekly follow-up handled entirely by our Assistant Team.</p>
					<ul class="package-features">
						<li><span class="icon">✅</span> Plan designed by Salakawy</li>
						<li><span class="icon">✅</span> Weekly assistant follow-up</li>
						<li><span class="icon">✅</span> Adjusted Flexible Diet</li>
						<li><span class="icon">✅</span> Gym & Home Workouts + Videos</li>
					</ul>
					<a href="/contact-us" class="btn btn-outline package-btn">Message Nour</a>
                    <p class="price-note">3 Months: 3200 EGP / 85$</p>
				</div>
			</div>

			<!-- Silver Package -->
			<div class="popular-spin-border">
				<div class="popular-badge">Best Seller</div>
				<div class="package-card glass-panel popular silver">
					<div class="package-header">
						<div class="package-logo-container silver-logo effect-shine">
							<img src="/salakawy-logo.png" alt="Silver" class="package-logo" />
						</div>
						<h3>Silver</h3>
						<span class="price-container">
							<span class="price-from">From</span>
							<span class="price">3700<small>EGP</small></span>
							<span class="price-duration">1 Month (or $80)</span>
						</span>
					</div>
					<div class="package-body">
						<p class="package-sub">Weekly check-ins directly with Salakawy to keep you on track.</p>
						<ul class="package-features">
							<li><span class="icon">🌟</span> <strong>Direct Salakawy follow-up weekly</strong></li>
							<li><span class="icon">🌟</span> WhatsApp Q & A anytime</li>
							<li><span class="icon">🌟</span> Diet Based on BMR & Food Choices</li>
							<li><span class="icon">🌟</span> Cardio and Abs routine</li>
							<li><span class="icon">🌟</span> Gym & Home Workouts</li>
						</ul>
						<a href="/contact-us" class="btn btn-primary package-btn">Book Silver</a>
						<p class="price-note">3 Months: 7900 EGP / 170$</p>
					</div>
				</div>
			</div>

			<!-- Gold Package -->
			<div class="package-card glass-panel premium golden">
				<div class="package-header">
                    <div class="package-logo-container gold-logo effect-shine effect-sparkle">
                        <img src="/salakawy-logo.png" alt="Gold" class="package-logo" />
                        <div class="sparkle s1"></div>
                        <div class="sparkle s2"></div>
                        <div class="sparkle s3"></div>
                        <div class="sparkle s4"></div>
                        <div class="sparkle s5"></div>
                    </div>
					<h3>Gold</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">4900<small>EGP</small></span>
						<span class="price-duration">1 Month (or $110)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">Daily check-ins, VIP attention, and direct phone access.</p>
					<ul class="package-features">
						<li><span class="icon">👑</span> <strong>Daily check-ins & updates</strong></li>
						<li><span class="icon">👑</span> <strong>My direct Phone Number</strong></li>
						<li><span class="icon">👑</span> Feel free to call me anytime</li>
						<li><span class="icon">👑</span> WhatsApp Q & A instantly</li>
						<li><span class="icon">👑</span> Full Diet & Workout Plan</li>
					</ul>
					<a href="/contact-us" class="btn btn-primary package-btn">Book Gold</a>
                    <p class="price-note">3 Months: 12900 EGP / 270$</p>
				</div>
			</div>

			<!-- Platinum Package -->
			<div class="package-card glass-panel platinum">
				<div class="package-header">
                    <div class="package-logo-container platinum-logo effect-lightning">
                        <img src="/salakawy-logo.png" alt="Platinum" class="package-logo" />
                        <div class="bolt b1"></div>
                        <div class="bolt b2"></div>
                    </div>
					<h3>Platinum</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">12700<small>EGP</small></span>
						<span class="price-duration">1 Month (or $230)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">The ultimate VIP experience. I reach out to you proactively every day.</p>
					<ul class="package-features">
						<li><span class="icon">💎</span> <strong>I reach out to YOU daily</strong></li>
						<li><span class="icon">💎</span> Proactive weight & mindset checks</li>
						<li><span class="icon">💎</span> Everything in Gold Package</li>
						<li><span class="icon">💎</span> Absolute maximum support level</li>
					</ul>
					<a href="/contact-us" class="btn btn-outline package-btn" style="border-color: var(--text-main);">Book Platinum</a>
                    <p class="price-note">3 Months: 29700 EGP / 590$</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.packages-bg {
		background-color: var(--bg-color);
	}

	.packages-desc {
		max-width: 600px;
		margin: 1rem auto 0 auto;
		color: var(--text-muted);
		font-size: 1.1rem;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	.packages-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		align-items: center;
        margin-top: 2rem;
	}

	.package-card {
		background: var(--surface-color);
		border-radius: var(--radius);
		transition: transform var(--transition), box-shadow var(--transition);
		border: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
	}

	.package-card:hover {
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
	}

    /* --- Spinning Border Wrapper (Best Seller) --- */

    /* Layer 1: Always-visible solid yellow border */
    .popular-spin-border {
        position: relative;
        border-radius: var(--radius);
        padding: 4px;
        background: #ffd700; /* Permanent yellow border */
        transform: scale(1.03);
        z-index: 2;
    }

    /* Layer 2: White rotating comet on top of the yellow */
    .popular-spin-border::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 4px;
        background: conic-gradient(from var(--spin-angle),
            transparent 0deg,
            transparent 300deg,
            rgba(255, 255, 255, 0) 310deg,
            rgba(255, 255, 255, 0.6) 330deg,
            rgba(255, 255, 255, 1) 350deg,
            rgba(255, 255, 255, 1) 355deg,
            rgba(255, 255, 255, 0) 360deg
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        animation: spin-comet 5s linear infinite;
        pointer-events: none;
    }

    @property --spin-angle {
        syntax: '<angle>';
        initial-value: 0deg;
        inherits: false;
    }

    @keyframes spin-comet {
        from { --spin-angle: 0deg; }
        to   { --spin-angle: 360deg; }
    }

    /* Badge on wrapper */
    .popular-badge {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--accent-color);
        color: #000;
        padding: 3px 15px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        box-shadow: 0 0 15px rgba(255, 255, 0, 0.4);
        z-index: 10;
    }

    .popular-badge::after {
        content: "";
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
        animation: badge-shine 3s infinite linear;
    }

    @keyframes badge-shine {
        0% { left: -100%; }
        20%, 100% { left: 100%; }
    }

    .popular {
        border: none;
        border-radius: calc(var(--radius) - 4px);
        background: #151515;
        position: relative;
        height: 100%;
    }

	.popular:hover {
		box-shadow: 0 15px 50px rgba(255, 255, 0, 0.15);
	}

    .popular-badge::after {
        content: "";
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
        animation: badge-shine 3s infinite linear;
    }

    @keyframes badge-shine {
        0% { left: -100%; }
        20%, 100% { left: 100%; }
    }

	/* Removed border-top lines — they conflicted with spin-border and looked messy */
	.platinum { border-top: none; }
	.standard { border-top: none; }
	.golden   { border-top: none; }
	.silver   { border-top: none; }

	.package-header {
		padding: 2.5rem 1.5rem 1.5rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	.package-header h3 {
		font-size: 1.8rem;
		margin-bottom: 0.5rem;
	}

	.golden .package-header h3 { color: #ffd700; }
    .standard .package-header h3 { color: #888; }

    /* Support Team (Standard) Logo Style */
    .standard-logo .package-logo {
        filter: grayscale(1) contrast(0.8) opacity(0.7);
    }
    
    /* Package Logos & Animations */
    .package-logo-container {
        position: relative;
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden; /* for shine effect */
    }

    .package-logo {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    /* Silver Look & Shine */
    .silver-logo .package-logo {
        /* Slightly lower base brightness so the high-intensity glare pops more */
        filter: grayscale(1) brightness(1.2) contrast(1.2);
    }

    .silver-logo {
        -webkit-mask-image: url('/salakawy-logo.png');
        mask-image: url('/salakawy-logo.png');
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
    }

    .effect-shine::after {
        content: "";
        position: absolute;
        top: 0;
        left: -200%;
        width: 150%; /* Massive glare width */
        height: 100%;
        background: linear-gradient(
            to right,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0.4) 30%,
            rgba(255, 255, 255, 1) 50%,
            rgba(255, 255, 255, 0.4) 70%,
            rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-30deg);
        z-index: 2;
        /* Aggressive, very visible sweep */
        animation: shine-sweep 1.5s infinite linear;
    }

    @keyframes shine-sweep {
        0% { left: -200%; }
        100% { left: 200%; }
    }

    /* Gold Look & Sparkle */
    .gold-logo .package-logo {
        filter: sepia(1) saturate(10) hue-rotate(-10deg) brightness(1.2) contrast(1.1);
    }

    .gold-logo {
        -webkit-mask-image: url('/salakawy-logo.png');
        mask-image: url('/salakawy-logo.png');
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
    }

    /* Gold specific shine color */
    .gold-logo.effect-shine::after {
        background: linear-gradient(
            to right,
            rgba(255, 215, 0, 0) 0%,
            rgba(255, 255, 255, 0) 40%,
            rgba(255, 255, 255, 0.9) 50%,
            rgba(255, 255, 255, 0) 60%,
            rgba(255, 215, 0, 0) 100%
        );
    }

    .sparkle {
        position: absolute;
        background: radial-gradient(circle, #fff 0%, transparent 70%);
        width: 6px;
        height: 6px;
        border-radius: 50%;
        opacity: 0;
        z-index: 5;
        /* Don't let the mask hide sparkles around the logo */
        -webkit-mask-image: none !important;
        mask-image: none !important;
    }

    .s1 { top: 25%; left: 25%; animation: sparkle-anim 3s infinite 0.2s; }
    .s2 { top: 60%; left: 75%; animation: sparkle-anim 2.5s infinite 1.5s; }
    .s3 { top: 75%; left: 35%; animation: sparkle-anim 4s infinite 0.8s; }
    .s4 { top: 30%; left: 80%; animation: sparkle-anim 2s infinite 1.2s; }
    .s5 { top: 80%; left: 60%; animation: sparkle-anim 3.5s infinite 0.5s; }

    @keyframes sparkle-anim {
        0%, 100% { opacity: 0; transform: scale(0) rotate(0deg); }
        10%, 20% { opacity: 1; transform: scale(2.5) rotate(45deg); }
        30% { opacity: 0; transform: scale(0) rotate(90deg); }
    }

    /* Platinum Look (Metallic White) & Lightning */
    .platinum-logo .package-logo {
        filter: grayscale(1) brightness(2.5) contrast(1.2) drop-shadow(0 0 10px rgba(255, 255, 255, 0.5));
    }

    .effect-lightning {
        animation: flicker 4s infinite;
    }

    .bolt {
        position: absolute;
        width: 2px;
        height: 20px;
        background: #00e5ff;
        box-shadow: 0 0 12px #00e5ff;
        opacity: 0;
    }

    .b1 { top: 10%; left: 70%; transform: rotate(15deg); animation: bolt-anim 5s infinite 1s; }
    .b2 { bottom: 20%; left: 20%; transform: rotate(-20deg); animation: bolt-anim 4s infinite 2.5s; }

    @keyframes bolt-anim {
        0%, 90%, 100% { opacity: 0; height: 0; }
        92% { opacity: 1; height: 30px; }
        95% { opacity: 0; height: 20px; }
    }

    @keyframes flicker {
        0%, 80%, 84%, 88%, 92%, 100% { filter: grayscale(1) brightness(2.8) contrast(1.3) drop-shadow(0 0 15px rgba(255, 255, 255, 0.6)); }
        81%, 85%, 89% { filter: brightness(5) contrast(2) drop-shadow(0 0 30px #00e5ff); }
    }


	.price-container {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		margin-top: 1rem;
	}

	.price-from {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--text-muted);
		margin-bottom: -4px;
	}

	.price {
		font-size: 2.2rem;
		font-weight: 700;
		color: var(--text-main);
        display: flex;
        align-items: baseline;
        gap: 4px;
	}

	.price small {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-muted);
	}

	.price-duration {
		font-size: 0.95rem;
		color: var(--text-muted);
        margin-top: -2px;
	}

	.package-body {
		padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
	}

	.package-sub {
		color: var(--text-main);
		font-weight: 600;
		margin-bottom: 1.5rem;
        min-height: 48px;
	}

	.package-features {
		list-style: none;
		margin-bottom: 2rem;
        flex-grow: 1;
	}

	.package-features li {
		margin-bottom: 1rem;
		display: flex;
		align-items: flex-start;
		color: var(--text-muted);
		line-height: 1.4;
        font-size: 0.95rem;
	}

	.package-features .icon {
		margin-right: 10px;
		font-size: 1.1rem;
	}

	.package-features strong {
		color: var(--text-main);
	}

	.package-btn {
		width: 100%;
		padding: 15px;
        text-align: center;
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s ease;
	}

    .package-btn:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(255, 255, 0, 0.25);
    }
    
    .price-note {
        text-align: center;
        margin-top: 1rem;
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }

	@media (max-width: 1200px) {
		.packages-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 3rem 1.5rem;
			align-items: stretch;
		}
		.popular {
			transform: scale(1);
		}
        .popular:hover {
		    transform: translateY(-5px);
	    }
	}

	@media (max-width: 768px) {
		.packages-grid {
			grid-template-columns: 1fr;
		}
        .package-sub {
            min-height: auto;
        }
	}
</style>
