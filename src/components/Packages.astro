                                <div class="pricing-list">
                                    <div class="pricing-row">
                                        <span class="duration" data-editable="packages_page:support.g_p1_dur" set:html={getVal(c, 'support.g_p1_dur', '3 Months:')} />
                                        <span class="current-price" data-editable="packages_page:support.g_p1_cur" set:html={getVal(c, 'support.g_p1_cur', '4700EGP/120$')} />
                                        <span class="old-price scratch-graffiti" data-editable="packages_page:support.g_p1_old" set:html={getVal(c, 'support.g_p1_old', '5900EGP')} />
