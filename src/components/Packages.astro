<style>
	.packages-bg {
		background-color: var(--bg-color);
	}

	.packages-desc {
		max-width: 600px;
		margin: 1rem auto 0 auto;
		color: var(--text-muted);
		font-size: 1.1rem;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	.packages-grid.main-packages {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		align-items: stretch;
        margin-top: 2rem;
	}

	.package-card {
		background: var(--surface-color);
		border-radius: var(--radius);
		transition: transform var(--transition), box-shadow var(--transition);
		border: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
	}

	.package-card:hover {
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
	}

    /* --- Spinning Border Wrapper (Best Seller) --- */

    /* Layer 1: Always-visible solid yellow border */
    .popular-spin-border {
        position: relative;
        border-radius: var(--radius);
        padding: 4px;
        background: #ffd700; /* Permanent yellow border */
        transform: scale(1.03);
        z-index: 2;
    }

    /* Layer 2: White rotating comet on top of the yellow */
    .popular-spin-border::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 4px;
        background: conic-gradient(from var(--spin-angle),
            transparent 0deg,
            transparent 300deg,
            rgba(255, 255, 255, 0) 310deg,
            rgba(255, 255, 255, 0.6) 330deg,
            rgba(255, 255, 255, 1) 350deg,
            rgba(255, 255, 255, 1) 355deg,
            rgba(255, 255, 255, 0) 360deg
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        animation: spin-comet 5s linear infinite;
        pointer-events: none;
    }

    @property --spin-angle {
        syntax: '<angle>';
        initial-value: 0deg;
        inherits: false;
    }

    @keyframes spin-comet {
        from { --spin-angle: 0deg; }
        to   { --spin-angle: 360deg; }
    }

    /* Badge on wrapper */
    .popular-badge {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--accent-color);
        color: #000;
        padding: 3px 15px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        box-shadow: 0 0 15px rgba(255, 255, 0, 0.4);
        z-index: 10;
    }

    .popular-badge::after {
