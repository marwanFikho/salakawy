                            <li><span class="icon">🥈</span> <span data-editable="packages_page:support.f3" set:html={getVal(c, 'support.f3', '<strong>Silver Tier:</strong> Includes weekly responses handled by my Assistant.')} /></li>
                            <li><span class="icon">📅</span> <span data-editable="packages_page:support.f4" set:html={getVal(c, 'support.f4', 'You\'ll get the program plan from me in the group, and your Assistant will help you stay on track with responses based on your package. ⏰')} /></li>
                            <li><span class="icon">🍏</span> <span data-editable="packages_page:support.f5" set:html={getVal(c, 'support.f5', 'Adjusted Flexible Diet')} /></li>
                            <li><span class="icon">🥩</span> <span data-editable="packages_page:support.f6" set:html={getVal(c, 'support.f6', 'Diet Based on your BMR And Your Food Choices')} /></li>
                            <li><span class="icon">💊</span> <span data-editable="packages_page:support.f7" set:html={getVal(c, 'support.f7', 'Supplements recommendation (protein powder - creatine - etc)(optional)')} /></li>
                            <li><span class="icon">🚴</span> <span data-editable="packages_page:support.f8" set:html={getVal(c, 'support.f8', 'Cardio and Abs routine')} /></li>
                            <li><span class="icon">🏋️</span> <span data-editable="packages_page:support.f9" set:html={getVal(c, 'support.f9', 'Gym And Home Workouts Explained With Videos')} /></li>
                        </ul>
                        
                        <div class="support-pricing-grid">
