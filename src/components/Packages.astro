	<!-- GSAP Platinum Effects -->
	<script>
		import gsap from 'gsap';

		document.addEventListener('astro:page-load', () => {
			const canvas = document.getElementById('plat-canvas') as HTMLCanvasElement;
			const logoWrap = document.getElementById('plat-logo-wrap') as HTMLElement;
			const shine = document.getElementById('plat-shine') as SVGRectElement;

			if (!canvas) return;

			const ctx = canvas.getContext('2d')!;

			function resize() {
				canvas.width = canvas.offsetWidth;
				canvas.height = canvas.offsetHeight;
			}
			resize();
			window.addEventListener('resize', resize);

			// ── Diamond particle class ──
			class DiamondParticle {
				x: number; y: number;
				size: number; opacity: number;
				vx: number; vy: number;
				rotation: number; rotSpeed: number;
				pulse: number; pulseSpeed: number;

				constructor() {
					this.x = Math.random() * canvas.width;
					this.y = Math.random() * canvas.height;
					this.size = Math.random() * 6 + 3;
					this.opacity = Math.random() * 0.7 + 0.1;
					this.vx = (Math.random() - 0.5) * 0.3;
					this.vy = (Math.random() - 0.5) * 0.3;
					this.rotation = Math.random() * Math.PI * 2;
					this.rotSpeed = (Math.random() - 0.5) * 0.03;
					this.pulse = Math.random() * Math.PI * 2;
					this.pulseSpeed = Math.random() * 0.04 + 0.01;
				}

				draw() {
					const s = this.size * (0.7 + 0.3 * Math.sin(this.pulse));
					const op = this.opacity * (0.5 + 0.5 * Math.sin(this.pulse));
					ctx.save();
					ctx.translate(this.x, this.y);
					ctx.rotate(this.rotation);
					ctx.globalAlpha = op;

					// Diamond shape (4-sided)
					ctx.beginPath();
					ctx.moveTo(0, -s);
					ctx.lineTo(s * 0.6, 0);
					ctx.lineTo(0, s);
					ctx.lineTo(-s * 0.6, 0);
					ctx.closePath();

					// Gradient fill per particle
					const grad = ctx.createLinearGradient(-s, -s, s, s);
					grad.addColorStop(0, `rgba(220,230,255,${op})`);
					grad.addColorStop(0.5, `rgba(255,255,255,${op})`);
					grad.addColorStop(1, `rgba(150,160,200,${op * 0.5})`);
					ctx.fillStyle = grad;
					ctx.fill();

					// Bright center sparkle cross
					ctx.globalAlpha = op * 0.9;
					ctx.strokeStyle = 'rgba(255,255,255,0.9)';
					ctx.lineWidth = 0.5;
					ctx.beginPath();
					ctx.moveTo(-s * 1.8, 0); ctx.lineTo(s * 1.8, 0);
					ctx.moveTo(0, -s * 1.8); ctx.lineTo(0, s * 1.8);
					ctx.stroke();

					ctx.restore();
				}

				update() {
					this.x += this.vx;
					this.y += this.vy;
					this.rotation += this.rotSpeed;
					this.pulse += this.pulseSpeed;
					if (this.x < -20) this.x = canvas.width + 20;
					if (this.x > canvas.width + 20) this.x = -20;
					if (this.y < -20) this.y = canvas.height + 20;
					if (this.y > canvas.height + 20) this.y = -20;
				}
			}

			const particles: DiamondParticle[] = Array.from({ length: 28 }, () => new DiamondParticle());

			function tick() {
				ctx.clearRect(0, 0, canvas.width, canvas.height);
				particles.forEach(p => { p.update(); p.draw(); });
				requestAnimationFrame(tick);
			}
			tick();

			// ── SVG shine sweep (GSAP) ──
			if (shine) {
				gsap.fromTo(shine,
					{ attr: { x: -120 } },
					{ attr: { x: 160 }, duration: 2, ease: 'none', repeat: -1, repeatDelay: 1.5 }
				);
			}

			// ── Logo float (GSAP) ──
			if (logoWrap) {
				gsap.to(logoWrap, {
					y: -12, duration: 2.5, repeat: -1, yoyo: true, ease: 'sine.inOut'
				});
			}
		});
	</script>
