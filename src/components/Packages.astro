						<li><span class="icon">💊</span> <span data-editable="packages_page:plat.f5" set:html={getVal(c, 'plat.f5', 'Supplements recommendation (protein powder - creatine - etc)(optional)')} /></li>
						<li><span class="icon">🚴</span> <span data-editable="packages_page:plat.f6" set:html={getVal(c, 'plat.f6', 'Cardio and Abs routine')} /></li>
