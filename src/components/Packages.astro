---
---
<section id="packages" class="section packages-bg">
	<div class="container">
		<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 4rem;">
			<h2 class="section-title fade-in-up" style="margin-bottom: 0;">Start Your Journey</h2>
			<span class="badge fade-in-up" style="margin-bottom: 0;">Pricing Plans</span>
			<p class="packages-desc fade-in-up delay-100" style="margin-top: 0;">Choose the level of contact that works best for you. Whether you need a daily roadmap or weekly updates, we have a plan to guarantee your transformation.</p>
		</div>
		
		<div class="packages-grid fade-in-up delay-200">
			<!-- Support Team Package -->
			<div class="package-card glass-panel standard">
				<div class="package-header">
					<h3>Support Team</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">1200<small>EGP</small></span>
						<span class="price-duration">1 Month (or $45)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">Weekly follow-up handled entirely by our Assistant Team.</p>
					<ul class="package-features">
						<li><span class="icon">✅</span> Plan designed by Salakawy</li>
						<li><span class="icon">✅</span> Weekly assistant follow-up</li>
						<li><span class="icon">✅</span> Adjusted Flexible Diet</li>
						<li><span class="icon">✅</span> Gym & Home Workouts + Videos</li>
					</ul>
					<a href="https://wa.me/201092151540" class="btn btn-outline package-btn" target="_blank" rel="noopener">Message Nour</a>
                    <p class="price-note">3 Months: 3200 EGP / 85$</p>
				</div>
			</div>

			<!-- Silver Package -->
			<div class="package-card glass-panel popular silver">
				<div class="popular-badge">Best Seller</div>
				<div class="package-header">
					<h3>Silver</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">3700<small>EGP</small></span>
						<span class="price-duration">1 Month (or $80)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">Weekly check-ins directly with Salakawy to keep you on track.</p>
					<ul class="package-features">
						<li><span class="icon">🌟</span> <strong>Direct Salakawy follow-up weekly</strong></li>
						<li><span class="icon">🌟</span> WhatsApp Q & A anytime</li>
						<li><span class="icon">🌟</span> Diet Based on BMR & Food Choices</li>
						<li><span class="icon">🌟</span> Cardio and Abs routine</li>
						<li><span class="icon">🌟</span> Gym & Home Workouts</li>
					</ul>
					<a href="https://wa.me/201217720267" class="btn btn-primary package-btn" target="_blank" rel="noopener">Book Silver</a>
                    <p class="price-note">3 Months: 7900 EGP / 170$</p>
				</div>
			</div>

			<!-- Gold Package -->
			<div class="package-card glass-panel premium golden">
				<div class="package-header">
					<h3>Gold</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">4900<small>EGP</small></span>
						<span class="price-duration">1 Month (or $110)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">Daily check-ins, VIP attention, and direct phone access.</p>
					<ul class="package-features">
						<li><span class="icon">👑</span> <strong>Daily check-ins & updates</strong></li>
						<li><span class="icon">👑</span> <strong>My direct Phone Number</strong></li>
						<li><span class="icon">👑</span> Feel free to call me anytime</li>
						<li><span class="icon">👑</span> WhatsApp Q & A instantly</li>
						<li><span class="icon">👑</span> Full Diet & Workout Plan</li>
					</ul>
					<a href="https://wa.me/201217720267" class="btn btn-primary package-btn" target="_blank" rel="noopener">Book Gold</a>
                    <p class="price-note">3 Months: 12900 EGP / 270$</p>
				</div>
			</div>

			<!-- Platinum Package -->
			<div class="package-card glass-panel platinum">
				<div class="package-header">
					<h3>Platinum</h3>
					<span class="price-container">
						<span class="price-from">From</span>
						<span class="price">12700<small>EGP</small></span>
						<span class="price-duration">1 Month (or $230)</span>
					</span>
				</div>
				<div class="package-body">
					<p class="package-sub">The ultimate VIP experience. I reach out to you proactively every day.</p>
					<ul class="package-features">
						<li><span class="icon">💎</span> <strong>I reach out to YOU daily</strong></li>
						<li><span class="icon">💎</span> Proactive weight & mindset checks</li>
						<li><span class="icon">💎</span> Everything in Gold Package</li>
						<li><span class="icon">💎</span> Absolute maximum support level</li>
					</ul>
					<a href="https://wa.me/201217720267" class="btn btn-outline package-btn" style="border-color: var(--text-main);" target="_blank" rel="noopener">Book Platinum</a>
                    <p class="price-note">3 Months: 29700 EGP / 590$</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.packages-bg {
		background-color: var(--bg-color);
	}

	.packages-desc {
		max-width: 600px;
		margin: 1rem auto 0 auto;
		color: var(--text-muted);
		font-size: 1.1rem;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	.packages-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		align-items: center;
        margin-top: 2rem;
	}

	.package-card {
		background: var(--surface-color);
		border-radius: var(--radius);
		transition: transform var(--transition), box-shadow var(--transition);
		border: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
	}

	.package-card:hover {
		transform: translateY(-5px);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
	}

	.popular {
		border: 2px solid var(--accent-color);
		transform: scale(1.03);
		z-index: 2;
        background: #151515;
	}

	.popular:hover {
		transform: scale(1.05) translateY(-5px);
		box-shadow: 0 15px 50px rgba(255, 255, 0, 0.1);
	}

	.popular-badge {
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		background: var(--accent-color);
		color: #000;
		padding: 3px 15px;
		border-radius: 20px;
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 1px;
		text-transform: uppercase;
        white-space: nowrap;
	}

	.platinum { border-top: 4px solid #e5e4e2; }
	.standard { border-top: 4px solid #888; }
	.golden { border-top: 4px solid #ffd700; }
	.silver { border-top: 4px solid var(--accent-color); }

	.package-header {
		padding: 2.5rem 1.5rem 1.5rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	.package-header h3 {
		font-size: 1.8rem;
		margin-bottom: 0.5rem;
	}

	.golden .package-header h3 { color: #ffd700; }
	.silver .package-header h3 { color: var(--accent-color); }
	.platinum .package-header h3 { color: #e5e4e2; }
    .standard .package-header h3 { color: #ccc; }

	.price-container {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		margin-top: 1rem;
	}

	.price-from {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--text-muted);
		margin-bottom: -4px;
	}

	.price {
		font-size: 2.2rem;
		font-weight: 700;
		color: var(--text-main);
        display: flex;
        align-items: baseline;
        gap: 4px;
	}

	.price small {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-muted);
	}

	.price-duration {
		font-size: 0.95rem;
		color: var(--text-muted);
        margin-top: -2px;
	}

	.package-body {
		padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
	}

	.package-sub {
		color: var(--text-main);
		font-weight: 600;
		margin-bottom: 1.5rem;
        min-height: 48px;
	}

	.package-features {
		list-style: none;
		margin-bottom: 2rem;
        flex-grow: 1;
	}

	.package-features li {
		margin-bottom: 1rem;
		display: flex;
		align-items: flex-start;
		color: var(--text-muted);
		line-height: 1.4;
        font-size: 0.95rem;
	}

	.package-features .icon {
		margin-right: 10px;
		font-size: 1.1rem;
	}

	.package-features strong {
		color: var(--text-main);
	}

	.package-btn {
		width: 100%;
		padding: 15px;
        text-align: center;
	}
    
    .price-note {
        text-align: center;
        margin-top: 1rem;
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }

	@media (max-width: 1200px) {
		.packages-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 3rem 1.5rem;
			align-items: stretch;
		}
		.popular {
			transform: scale(1);
		}
        .popular:hover {
		    transform: translateY(-5px);
	    }
	}

	@media (max-width: 768px) {
		.packages-grid {
			grid-template-columns: 1fr;
		}
        .package-sub {
            min-height: auto;
        }
	}
</style>
