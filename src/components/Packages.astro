---
import { Image } from 'astro:assets';
import logo from '../assets/salakawy-logo.png';
import { getContent, getVal } from '../backend/content';
import db from '../backend/db';

const c = getContent('packages_page');

const stmt = db.prepare('SELECT content FROM site_content WHERE id = ?');
const row = stmt.get('contacts') as { content: string } | undefined;
let asstName = 'Assistant';
if (row) {
    try {
        const contacts = JSON.parse(row.content);
        if (contacts && contacts.assistant && contacts.assistant.name) {
            asstName = contacts.assistant.name;
        }
    } catch (e) {}
}
---
<section id="packages" class="section packages-bg">
	<div class="container">
		<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 4rem;">
			<h2 class="section-title fade-in-up" style="margin-bottom: 0;" data-editable="packages_page:header.title" set:html={getVal(c, 'header.title', 'Start Your Journey')} />
			<span class="badge fade-in-up" style="margin-bottom: 0;" data-editable="packages_page:header.badge" set:html={getVal(c, 'header.badge', 'Pricing Plans')} />
			<p class="packages-desc fade-in-up delay-100" style="margin-top: 0;" data-editable="packages_page:header.desc" set:html={getVal(c, 'header.desc', 'Choose the package that works best for you. Whether you need a daily roadmap to <strong>force your success</strong> or weekly updates, you must <strong>make a decision today</strong> to <strong>guarantee your transformation</strong>.')} />
		</div>
		
		<div class="packages-grid fade-in-up delay-200 main-packages">
			<!-- Silver Package -->
			<div class="popular-spin-border">
				<div class="popular-badge">Best Seller</div>
				<div class="package-card glass-panel popular silver">
					<div class="package-header">
						<div class="package-logo-container silver-logo effect-shine">
							<img src="/salakawy-logo.png" alt="Silver" class="package-logo" />
						</div>
						<h3 data-editable="packages_page:silver.title" set:html={getVal(c, 'silver.title', 'Silver')} />
						<p class="package-sub" style="min-height: auto; margin-bottom: 0;" data-editable="packages_page:silver.subtitle" set:html={getVal(c, 'silver.subtitle', 'Great For Professional Users')} />
					</div>
					<div class="package-body">
						<ul class="package-features">
							<li><span class="icon">📅</span> <span data-editable="packages_page:silver.f1" set:html={getVal(c, 'silver.f1', 'Weekly responses and updates with Salakawy directly to keep you on track and motivated. ⏰')} /></li>
							<li><span class="icon">💬</span> <span data-editable="packages_page:silver.f2" set:html={getVal(c, 'silver.f2', 'Q & A via whatsapp.')} /></li>
							<li><span class="icon">🍏</span> <span data-editable="packages_page:silver.f3" set:html={getVal(c, 'silver.f3', 'Adjusted Flexible Diet')} /></li>
							<li><span class="icon">🥩</span> <span data-editable="packages_page:silver.f4" set:html={getVal(c, 'silver.f4', 'Diet Based on your BMR And Your Food Choices')} /></li>
							<li><span class="icon">💊</span> <span data-editable="packages_page:silver.f5" set:html={getVal(c, 'silver.f5', 'Supplements recommendation (protein powder - creatine - etc)(optional)')} /></li>
							<li><span class="icon">🚴</span> <span data-editable="packages_page:silver.f6" set:html={getVal(c, 'silver.f6', 'Cardio and Abs routine')} /></li>
							<li><span class="icon">🏋️</span> <span data-editable="packages_page:silver.f7" set:html={getVal(c, 'silver.f7', 'Gym And Home Workouts Explained With Videos')} /></li>
						</ul>
						<div class="pricing-list">
							<div class="pricing-row">
								<span class="duration" data-editable="packages_page:silver.p1_dur" set:html={getVal(c, 'silver.p1_dur', '3 Months:')} />
								<span class="current-price" data-editable="packages_page:silver.p1_cur" set:html={getVal(c, 'silver.p1_cur', '7900EGP/170$')} />
								<span class="old-price scratch-graffiti" data-editable="packages_page:silver.p1_old" set:html={getVal(c, 'silver.p1_old', '11200EGP')} />
								<span class="best-seller-text" data-editable="packages_page:silver.badge" set:html={getVal(c, 'silver.badge', '(Best Seller)')} />
							</div>
							<div class="pricing-row">
								<span class="duration" data-editable="packages_page:silver.p2_dur" set:html={getVal(c, 'silver.p2_dur', '1 Month:')} />
								<span class="current-price" data-editable="packages_page:silver.p2_cur" set:html={getVal(c, 'silver.p2_cur', '3700EGP/80$')} />
								<span class="old-price scratch-graffiti" data-editable="packages_page:silver.p2_old" set:html={getVal(c, 'silver.p2_old', '4900EGP')} />
							</div>
