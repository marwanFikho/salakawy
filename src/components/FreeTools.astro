---
---
<section id="free-tools" class="section glass-section">
	<div class="container">
		<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 3rem;">
			<h2 class="section-title fade-in-up" style="margin-bottom: 0;">Calorie Calculator</h2>
			<p class="tools-desc fade-in-up delay-100" style="margin-top: 0;">Find out exactly how many calories your body needs to lose weight, maintain, or build muscle. <strong>Stop guessing</strong> and let science <strong>start your journey today</strong>.</p>
		</div>

		<div class="calc-card glass-panel fade-in-up delay-200">

			<form id="macro-form" class="calc-form">
				<!-- Gender -->
				<div class="gender-row">
					<label>Gender</label>
					<div class="radio-group">
						<label class="radio-label">
							<input type="radio" name="gender" value="male" />
							<span class="radio-custom"></span>
							Male
						</label>
						<label class="radio-label">
							<input type="radio" name="gender" value="female" checked />
							<span class="radio-custom"></span>
							Female
						</label>	
					</div>
				</div>

				<!-- Age + Height + Weight -->
				<div class="input-row">
					<div class="input-group">
						<label for="age">Age</label>
						<div class="input-wrap">
							<input type="number" id="age" min="15" max="80" required placeholder="25" />
							<span class="input-unit">yrs</span>
						</div>
					</div>

					<!-- Metric height -->
					<div class="input-group" id="height-metric">
						<label for="height-cm">Height</label>
						<div class="input-wrap">
							<input type="number" id="height-cm" min="100" max="250" placeholder="175" />
							<span class="input-unit">cm</span>
						</div>
					</div>

					<!-- Weight -->
					<div class="input-group">
						<label for="weight-val" id="weight-label">Weight</label>
						<div class="input-wrap">
							<input type="number" id="weight-val" min="30" max="500" step="0.1" placeholder="70" />
							<span class="input-unit" id="weight-unit">kg</span>
						</div>
					</div>
				</div>

				<!-- Activity -->
				<div class="input-group">
					<label for="activity">Activity Level</label>
					<select id="activity">
							<option value="1.0">Basal Metabolic Rate (BMR)</option>
							<option value="1.2">Sedentary (little or no exercise)</option>
							<option value="1.375">Light (exercise 1-3 times/week)</option>
							<option value="1.465">Moderate (exercise 4-5 times/week)</option>
							<option value="1.55" selected>Active (daily exercise or intense exercise 3-4 times/week)</option>
							<option value="1.725">Very Active (intense exercise 6-7 times/week)</option>
							<option value="1.9">Extra Active (very intense exercise daily, or physical job)</option>
					</select>
				</div>

				<button type="submit" class="btn btn-primary calculate-btn">Calculate Calories</button>
			</form>
		</div>

		<!-- Results -->
		<div id="results-section" class="results-section hidden">

			<!-- BMR Row -->
			<div class="bmr-banner">
				Your Basal Metabolic Rate (BMR): <strong id="res-bmr">--</strong> kcal/day
			</div>

			<!-- Main Goals Table -->
			<div class="results-card glass-panel">
				<h3 class="results-title">Daily Calorie Goals</h3>
				<div class="goals-table-wrap">
					<table class="goals-table">
						<thead>
							<tr>
								<th>Goal</th>
								<th>Calories / Day</th>
								<th>Change</th>
							</tr>
						</thead>
						<tbody>
							<tr class="row-maintain">
								<td><span class="goal-dot maintain"></span> Maintain Weight</td>
								<td class="cal-val" id="cal-maintain">--</td>
								<td class="change-val">—</td>
							</tr>
							<tr class="row-loss">
								<td><span class="goal-dot loss-mild"></span> Mild Weight Loss</td>
								<td class="cal-val" id="cal-loss-mild">--</td>
								<td class="change-val">− 0.25 kg/week</td>
							</tr>
							<tr class="row-loss">
								<td><span class="goal-dot loss"></span> Weight Loss</td>
								<td class="cal-val" id="cal-loss">--</td>
								<td class="change-val">− 0.5 kg/week</td>
							</tr>
							<tr class="row-loss extreme" id="row-extreme-loss">
								<td><span class="goal-dot loss-extreme"></span> Extreme Weight Loss</td>
								<td class="cal-val" id="cal-loss-extreme">--</td>
								<td class="change-val">− 1 kg/week</td>
							</tr>
							<tr class="row-gain">
								<td><span class="goal-dot gain-mild"></span> Mild Weight Gain</td>
								<td class="cal-val" id="cal-gain-mild">--</td>
								<td class="change-val">+ 0.25 kg/week</td>
							</tr>
							<tr class="row-gain">
								<td><span class="goal-dot gain"></span> Weight Gain</td>
								<td class="cal-val" id="cal-gain">--</td>
								<td class="change-val">+ 0.5 kg/week</td>
							</tr>
							<tr class="row-gain">
								<td><span class="goal-dot gain-fast"></span> Fast Weight Gain</td>
								<td class="cal-val" id="cal-gain-fast">--</td>
								<td class="change-val">+ 1 kg/week</td>
							</tr>
						</tbody>
					</table>
				</div>
				<p id="low-calorie-warning" class="warning-text hidden">⚠️ Consuming fewer than 1,200 calories per day (women) or 1,500 calories (men) is not recommended without medical supervision.</p>
			</div>

			<!-- Macros Table -->
			<div class="results-card glass-panel">
				<h3 class="results-title">Macronutrient Breakdown <span class="subtitle">(Based on your goals)</span></h3>
				<div class="goals-table-wrap">
					<table class="goals-table">
						<thead>
							<tr>
								<th>Goal</th>
								<th>Protein (25-40%)</th>
								<th>Carbs (25-40%)</th>
								<th>Fats (15-25%)</th>
							</tr>
						</thead>
						<tbody>
							<tr class="row-maintain">
								<td><span class="goal-dot maintain"></span> Maintain Weight</td>
								<td id="macro-maintain-protein" class="cal-val">--</td>
								<td id="macro-maintain-carbs" class="cal-val">--</td>
								<td id="macro-maintain-fats" class="cal-val">--</td>
							</tr>
							<tr class="row-loss">
								<td><span class="goal-dot loss"></span> Weight Loss</td>
								<td id="macro-loss-protein" class="cal-val">--</td>
								<td id="macro-loss-carbs" class="cal-val">--</td>
								<td id="macro-loss-fats" class="cal-val">--</td>
							</tr>
							<tr class="row-gain">
								<td><span class="goal-dot gain"></span> Weight Gain</td>
								<td id="macro-gain-protein" class="cal-val">--</td>
								<td id="macro-gain-carbs" class="cal-val">--</td>
								<td id="macro-gain-fats" class="cal-val">--</td>
							</tr>
						</tbody>
					</table>
				</div>
                <p class="warning-text" style="background: rgba(255, 255, 255, 0.05); color: #ccc; border-color: rgba(255,255,255,0.1); margin-top: 1rem; border-left: 3px solid var(--accent-color);">
                    <strong>💡 Pro Tip:</strong> 1P = 4C (1 gram of protein = 4 calories), 1C = 4C (1 gram of carbs = 4 calories), 1F = 9C (1 gram of fat = 9 calories). The exact gram amount you choose within these ranges depends entirely on your body type and preferences.
                </p>
			</div>

			<!-- Zigzag Table -->
			<div class="results-card glass-panel">
				<h3 class="results-title">Zigzag Calorie Cycling <span class="subtitle">(7-day schedule to avoid plateaus)</span></h3>
				<div class="zigzag-tables">
					<div class="zigzag-block">
						<p class="zigzag-label">Schedule 1 — Alternating</p>
						<table class="zigzag-table">
							<thead><tr><th>Day</th><th>Calories</th></tr></thead>
							<tbody id="zigzag-1"></tbody>
						</table>
					</div>
					<div class="zigzag-block">
						<p class="zigzag-label">Schedule 2 — Gradual</p>
						<table class="zigzag-table">
							<thead><tr><th>Day</th><th>Calories</th></tr></thead>
							<tbody id="zigzag-2"></tbody>
						</table>
					</div>
				</div>
			</div>

			<!-- Activity Comparison -->
			<div class="results-card glass-panel">
				<h3 class="results-title">Calorie Needs by Activity Level</h3>
				<div class="activity-table-wrap">
					<table class="activity-table">
						<thead>
							<tr>
								<th>Activity Level</th>
								<th>Maintenance Calories</th>
							</tr>
						</thead>
						<tbody id="activity-comparison"></tbody>
					</table>
				</div>
			</div>

			<!-- CTA -->
			<div class="results-cta glass-panel">
				<p>These are estimates based on the Mifflin-St Jeor equation. For a fully custom plan that's tracked and adjusted to <strong>force your success</strong>, you need to <strong>claim your transformation now</strong>.</p>
				<a href="#packages" class="btn btn-primary">View Coaching Packages →</a>
			</div>

		</div>
	</div>
</section>

<style>
	.glass-section {
		position: relative;
		background: linear-gradient(to bottom, var(--surface-hover), var(--bg-color));
	}

	.tools-desc {
		max-width: 650px;
		margin: 1rem auto;
		color: var(--text-muted);
		font-size: 1.1rem;
		text-align: center;
	}

	/* ── Calculator Card ── */
	.calc-card {
		max-width: 760px;
		margin: 0 auto;
		padding: 2.5rem;
		border-radius: var(--radius);
	}

	.unit-toggle {
		display: flex;
		gap: 0;
		background: rgba(255,255,255,0.05);
		border-radius: 8px;
		padding: 4px;
		width: fit-content;
		margin-bottom: 2rem;
	}

	.unit-btn {
		padding: 8px 24px;
		border: none;
		background: transparent;
		color: var(--text-muted);
		border-radius: 6px;
		cursor: pointer;
		font-family: inherit;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.25s ease;
	}

	.unit-btn.active {
		background: var(--accent-color);
		color: #111;
	}

	/* ── Form ── */
	.calc-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.gender-row > label {
		font-weight: 600;
		color: var(--text-main);
		font-size: 0.95rem;
		display: block;
		margin-bottom: 0.75rem;
	}

	.radio-group {
		display: flex;
		gap: 2rem;
	}

	.radio-label {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		cursor: pointer;
		font-weight: 500;
		color: var(--text-muted);
		transition: color 0.2s;
	}

	.radio-label input[type="radio"] {
		display: none;
	}

	.radio-custom {
		width: 18px;
		height: 18px;
		border-radius: 50%;
		border: 2px solid rgba(255,255,255,0.2);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: border-color 0.2s;
		flex-shrink: 0;
	}

	.radio-label input[type="radio"]:checked ~ .radio-custom {
		border-color: var(--accent-color);
		background: radial-gradient(circle, var(--accent-color) 45%, transparent 50%);
	}

	.radio-label input[type="radio"]:checked ~ * {
		color: var(--text-main);
	}

	.input-row {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.input-row-inner {
		display: flex;
		gap: 0.5rem;
	}

	.input-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.input-group label {
		font-weight: 600;
		color: var(--text-main);
		font-size: 0.95rem;
	}

	.input-wrap {
		position: relative;
		display: flex;
		align-items: center;
	}

	.input-wrap input {
		width: 100%;
		padding: 12px 44px 12px 16px;
		background: rgba(0,0,0,0.5);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 8px;
		color: #fff;
		font-family: inherit;
		font-size: 1rem;
		outline: none;
		transition: border-color 0.2s;
	}

	.input-wrap input:focus {
		border-color: var(--accent-color);
	}

	.input-unit {
		position: absolute;
		right: 12px;
		font-size: 0.85rem;
		color: var(--text-muted);
		pointer-events: none;
	}

	select {
		width: 100%;
		padding: 12px 16px;
		background: rgba(0,0,0,0.5);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 8px;
		color: #fff;
		font-family: inherit;
		font-size: 1rem;
		outline: none;
		transition: border-color 0.2s;
		cursor: pointer;
	}

	select:focus { border-color: var(--accent-color); }
	select option { background: #111; color: #fff; }

	.calculate-btn {
		width: 100%;
		padding: 16px;
		font-size: 1.1rem;
		margin-top: 0.5rem;
		border-radius: 10px;
	}

	.hidden { display: none !important; }

	/* ── Results ── */
	.results-section {
		max-width: 900px;
		margin: 3rem auto 0;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.results-card {
		border-radius: var(--radius);
		padding: 2rem;
	}

	.results-title {
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
		color: var(--text-main);
	}

	.results-title .subtitle {
		font-size: 0.85rem;
		font-weight: 400;
		color: var(--text-muted);
	}

	.bmr-banner {
		background: rgba(255,255,0,0.08);
		border: 1px solid rgba(255,255,0,0.2);
		padding: 1rem 1.5rem;
		border-radius: 10px;
		color: var(--text-muted);
		font-size: 1rem;
		text-align: center;
	}

	.bmr-banner strong {
		color: var(--accent-color);
		font-size: 1.2rem;
	}

	/* Goals table */
	.goals-table-wrap { overflow-x: auto; }
	.goals-table {
		width: 100%;
		border-collapse: collapse;
	}
	.goals-table th {
		text-align: left;
		padding: 0.75rem 1rem;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--text-muted);
		border-bottom: 1px solid rgba(255,255,255,0.07);
	}
	.goals-table td {
		padding: 0.9rem 1rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
		color: var(--text-muted);
		font-size: 0.95rem;
	}
	.goals-table tr:last-child td { border-bottom: none; }
	.goals-table tr:hover td { background: rgba(255,255,255,0.03); }

	.cal-val {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text-main);
	}

	.goal-dot {
		display: inline-block;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		margin-right: 8px;
		vertical-align: middle;
	}
	.goal-dot.maintain    { background: var(--accent-color); }
	.goal-dot.loss-mild   { background: #7ec8a0; }
	.goal-dot.loss        { background: #3ebd7a; }
	.goal-dot.loss-extreme{ background: #e05c5c; }
	.goal-dot.gain-mild   { background: #80b4f8; }
	.goal-dot.gain        { background: #4a90e2; }
	.goal-dot.gain-fast   { background: #a77bf5; }

	.row-maintain td:first-child { color: var(--accent-color); font-weight: 600; }
	.row-loss td:first-child { color: #5ee89a; }
	.row-gain td:first-child { color: #80b4f8; }
	.row-loss.extreme td:first-child { color: #e07070; }

	.change-val { font-size: 0.9rem; color: var(--text-muted); }

	.warning-text {
		margin-top: 1rem;
		font-size: 0.85rem;
		color: #e07070;
		background: rgba(224,112,112,0.08);
		border: 1px solid rgba(224,112,112,0.2);
		padding: 0.75rem 1rem;
		border-radius: 8px;
	}

	/* Zigzag */
	.zigzag-tables {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}
	.zigzag-label {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
	}
	.zigzag-table {
		width: 100%;
		border-collapse: collapse;
	}
	.zigzag-table th {
		text-align: left;
		padding: 0.6rem 0.75rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		color: var(--text-muted);
		border-bottom: 1px solid rgba(255,255,255,0.07);
	}
	.zigzag-table td {
		padding: 0.6rem 0.75rem;
		font-size: 0.9rem;
		color: var(--text-muted);
		border-bottom: 1px solid rgba(255,255,255,0.04);
	}
	.zigzag-table td:last-child { font-weight: 600; color: var(--text-main); }
	.zigzag-table tr.highlight td { background: rgba(255,255,0,0.05); color: var(--accent-color); }

	/* Activity comparison */
	.activity-table-wrap { overflow-x: auto; }
	.activity-table {
		width: 100%;
		border-collapse: collapse;
	}
	.activity-table th {
		text-align: left;
		padding: 0.75rem 1rem;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--text-muted);
		border-bottom: 1px solid rgba(255,255,255,0.07);
	}
	.activity-table td {
		padding: 0.85rem 1rem;
		font-size: 0.9rem;
		color: var(--text-muted);
		border-bottom: 1px solid rgba(255,255,255,0.04);
	}
	.activity-table td:last-child { font-weight: 600; color: var(--text-main); }
	.activity-table tr.active-row td { background: rgba(255,255,0,0.05);  }
	.activity-table tr.active-row td:first-child { color: var(--accent-color); }

	/* CTA */
	.results-cta {
		border-radius: var(--radius);
		padding: 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		border: 1px solid rgba(255,255,0,0.15);
	}
	.results-cta p {
		color: var(--text-muted);
		max-width: 600px;
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.calc-card { padding: 1.75rem 1.25rem; }
		.input-row { grid-template-columns: 1fr; }
		.macros-row { grid-template-columns: 1fr; }
		.zigzag-tables { grid-template-columns: 1fr; }
		.results-card { padding: 1.5rem 1.25rem; }
	}
</style>

<script>
document.addEventListener('astro:page-load', () => {
	const form = document.getElementById('macro-form');
	if (!form) return;

	// Unit toggle
	let isMetric = true;
	document.getElementById('btn-metric')?.addEventListener('click', () => {
		isMetric = true;
		document.getElementById('btn-metric').classList.add('active');
		document.getElementById('btn-imperial').classList.remove('active');
		document.getElementById('height-metric').classList.remove('hidden');
		document.getElementById('height-imperial').classList.add('hidden');
		document.getElementById('weight-unit').textContent = 'kg';
		document.getElementById('weight-label').textContent = 'Weight';
		const wInput = document.getElementById('weight-val');
		if (wInput.dataset.lbs) {
			wInput.value = Math.round(parseFloat(wInput.dataset.lbs) / 2.205 * 10) / 10;
			delete wInput.dataset.lbs;
		}
	});

	document.getElementById('btn-imperial')?.addEventListener('click', () => {
		isMetric = false;
		document.getElementById('btn-imperial').classList.add('active');
		document.getElementById('btn-metric').classList.remove('active');
		document.getElementById('height-metric').classList.add('hidden');
		document.getElementById('height-imperial').classList.remove('hidden');
		document.getElementById('weight-unit').textContent = 'lbs';
		document.getElementById('weight-label').textContent = 'Weight';
		const wInput = document.getElementById('weight-val');
		if (wInput.value) {
			const lbs = Math.round(parseFloat(wInput.value) * 2.205);
			wInput.dataset.lbs = lbs;
			wInput.value = lbs;
		}
	});

	form.addEventListener('submit', (e) => {
		e.preventDefault();

		const gender = document.querySelector('input[name="gender"]:checked')?.value || 'male';
		const age = parseFloat(document.getElementById('age').value);
		let weightKg, heightCm;

		if (isMetric) {
			weightKg = parseFloat(document.getElementById('weight-val').value);
			heightCm = parseFloat(document.getElementById('height-cm').value);
		} else {
			const lbs = parseFloat(document.getElementById('weight-val').value);
			const ft  = parseFloat(document.getElementById('height-ft').value) || 0;
			const inc = parseFloat(document.getElementById('height-in').value) || 0;
			weightKg = lbs / 2.2046;
			heightCm = (ft * 12 + inc) * 2.54;
		}

		const activityFactor = parseFloat(document.getElementById('activity').value);

		if (!age || !weightKg || !heightCm) return;

		// Mifflin-St Jeor BMR (Matches calculator.net)
		let bmr = 10 * weightKg + 6.25 * heightCm - 5 * age;
		bmr += gender === 'male' ? 5 : -161;

		const tdee = Math.round(bmr * activityFactor);

		// Goals (calculator.net standard: 1lb ≈ 3500 cals/week, 500 cals/day)
		const vals = {
			maintain:    tdee,
			lossMild:    tdee - 250,    // ~0.25 kg/week
			loss:        tdee - 500,    // ~0.5 kg/week
			lossExtreme: tdee - 1000,   // ~1 kg/week
			gainMild:    tdee + 250,
			gain:        tdee + 500,
			gainFast:    tdee + 1000,
		};

		// Update BMR banner
		document.getElementById('res-bmr').textContent = Math.round(bmr).toLocaleString();

		// Update goal table
		document.getElementById('cal-maintain').textContent    = vals.maintain.toLocaleString() + ' kcal';
		document.getElementById('cal-loss-mild').textContent   = vals.lossMild.toLocaleString() + ' kcal';
		document.getElementById('cal-loss').textContent        = vals.loss.toLocaleString() + ' kcal';
		document.getElementById('cal-loss-extreme').textContent= (vals.lossExtreme > 0 ? vals.lossExtreme.toLocaleString() : 'N/A') + ' kcal';
		document.getElementById('cal-gain-mild').textContent   = vals.gainMild.toLocaleString() + ' kcal';
		document.getElementById('cal-gain').textContent        = vals.gain.toLocaleString() + ' kcal';
		document.getElementById('cal-gain-fast').textContent   = vals.gainFast.toLocaleString() + ' kcal';

		// Warning for very low calories
		const minSafe = gender === 'female' ? 1200 : 1500;
		const warnEl = document.getElementById('low-calorie-warning');
		if (vals.loss < minSafe || vals.lossExtreme < minSafe) {
			warnEl.classList.remove('hidden');
		} else {
			warnEl.classList.add('hidden');
		}

		// Calculate Macros based on min/max percentage ranges
		function calcMacros(cals) {
			const pMin = Math.round((cals * 0.25) / 4);
			const pMax = Math.round((cals * 0.40) / 4);
			
			const cMin = Math.round((cals * 0.25) / 4);
			const cMax = Math.round((cals * 0.40) / 4);

			const fMin = Math.round((cals * 0.15) / 9);
			const fMax = Math.round((cals * 0.25) / 9);
			
			return {
				p: `${pMin} - ${pMax}g`,
				c: `${cMin} - ${cMax}g`,
				f: `${fMin} - ${fMax}g`
			};
		}

		const macMaintain = calcMacros(vals.maintain);
		const macLoss = calcMacros(vals.loss);
		const macGain = calcMacros(vals.gain);

		document.getElementById('macro-maintain-protein').textContent = macMaintain.p;
		document.getElementById('macro-maintain-carbs').textContent = macMaintain.c;
		document.getElementById('macro-maintain-fats').textContent = macMaintain.f;

		document.getElementById('macro-loss-protein').textContent = macLoss.p;
		document.getElementById('macro-loss-carbs').textContent = macLoss.c;
		document.getElementById('macro-loss-fats').textContent = macLoss.f;

		document.getElementById('macro-gain-protein').textContent = macGain.p;
		document.getElementById('macro-gain-carbs').textContent = macGain.c;
		document.getElementById('macro-gain-fats').textContent = macGain.f;

		// Zigzag Schedule 1: Alternating high/low
		const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
		const z1Multipliers = [1.10, 0.90, 1.15, 0.90, 1.10, 1.15, 0.70];
		const z2Multipliers = [1.00, 1.05, 1.10, 0.90, 0.85, 1.10, 1.00];

		const zBody1 = document.getElementById('zigzag-1');
		const zBody2 = document.getElementById('zigzag-2');
		zBody1.innerHTML = '';
		zBody2.innerHTML = '';

		days.forEach((day, i) => {
			const c1 = Math.round(tdee * z1Multipliers[i]);
			const c2 = Math.round(tdee * z2Multipliers[i]);
			const highlight1 = Math.abs(c1 - tdee) > tdee * 0.08 ? 'highlight' : '';
			const highlight2 = Math.abs(c2 - tdee) > tdee * 0.08 ? 'highlight' : '';
			zBody1.innerHTML += `<tr class="${highlight1}"><td>${day}</td><td>${c1.toLocaleString()}</td></tr>`;
			zBody2.innerHTML += `<tr class="${highlight2}"><td>${day}</td><td>${c2.toLocaleString()}</td></tr>`;
		});

		// Activity comparison table
		const activityLevels = [
			{ label: 'Basal Metabolic Rate (BMR)', factor: 1.0 },
			{ label: 'Sedentary (little or no exercise)', factor: 1.2 },
			{ label: 'Light (exercise 1-3 times/week)', factor: 1.375 },
			{ label: 'Moderate (exercise 4-5 times/week)', factor: 1.465 },
			{ label: 'Active (daily exercise or intense exercise 3-4 times/week)', factor: 1.55 },
			{ label: 'Very Active (intense exercise 6-7 times/week)', factor: 1.725 },
			{ label: 'Extra Active (very intense exercise daily, or physical job)', factor: 1.9 },
		];
		const actBody = document.getElementById('activity-comparison');
		actBody.innerHTML = '';
		activityLevels.forEach(lvl => {
			const cals = Math.round(bmr * lvl.factor);
			const isSelected = Math.abs(lvl.factor - activityFactor) < 0.01;
			actBody.innerHTML += `<tr class="${isSelected ? 'active-row' : ''}">
				<td>${lvl.label}${isSelected ? ' ✓' : ''}</td>
				<td>${cals.toLocaleString()} kcal</td>
			</tr>`;
		});

		// Show results
		document.getElementById('results-section').classList.remove('hidden');
		document.getElementById('results-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
	});
});
</script>
