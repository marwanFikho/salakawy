---
---
<section id="free-tools" class="section glass-section">
	<div class="container">
		<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 3rem;">
			<h2 class="section-title fade-in-up" style="margin-bottom: 0;">Calculate Your Macros</h2>
			<p class="tools-desc fade-in-up delay-100" style="margin-top: 0;">Don't guess your nutrition. Find out exactly how many calories and macros your body needs to burn fat or build muscle, tailored precisely to your metrics.</p>
		</div>

		<div class="calculator-container glass-panel fade-in-up delay-200">
			<form id="macro-form" class="calc-form">
				<div class="input-group">
					<label for="gender">Gender</label>
					<select id="gender" required>
						<option value="male">Male</option>
						<option value="female">Female</option>
					</select>
				</div>
                
				<div class="input-row">
					<div class="input-group">
						<label for="age">Age (years)</label>
						<input type="number" id="age" min="15" max="100" required placeholder="e.g. 25" />
					</div>
					<div class="input-group">
						<label for="weight">Weight (kg)</label>
						<input type="number" id="weight" min="30" max="300" step="0.1" required placeholder="e.g. 75" />
					</div>
					<div class="input-group">
						<label for="height">Height (cm)</label>
						<input type="number" id="height" min="100" max="250" required placeholder="e.g. 175" />
					</div>
				</div>

				<div class="input-group">
					<label for="activity">Activity Level</label>
					<select id="activity" required>
						<option value="1.2">Sedentary (Little or no exercise)</option>
						<option value="1.375">Lightly Active (Light exercise 1-3 days/week)</option>
						<option value="1.55" selected>Moderately Active (Moderate exercise 3-5 days/week)</option>
						<option value="1.725">Very Active (Hard exercise 6-7 days/week)</option>
						<option value="1.9">Super Active (Very hard physical job or training twice a day)</option>
					</select>
				</div>
                
                <div class="input-group">
					<label for="goal">Your Goal</label>
					<select id="goal" required>
						<option value="cut">Lose Weight (Deficit)</option>
						<option value="maintain" selected>Maintain Weight</option>
						<option value="bulk">Build Muscle (Surplus)</option>
					</select>
				</div>

				<button type="submit" class="btn btn-primary calculate-btn">Calculate My Macros</button>
			</form>

			<div id="results-panel" class="results-panel hidden">
				<h3 class="results-title">Your Daily Targets</h3>
				<div class="calories-result">
					<span id="res-calories" class="big-number">--</span>
					<span class="label">kcal / day</span>
				</div>
				
				<div class="macros-row">
					<div class="macro-box protein">
						<span class="macro-label">Protein</span>
						<span id="res-protein" class="macro-val">--g</span>
					</div>
					<div class="macro-box carbs">
						<span class="macro-label">Carbs</span>
						<span id="res-carbs" class="macro-val">--g</span>
					</div>
					<div class="macro-box fats">
						<span class="macro-label">Fats</span>
						<span id="res-fats" class="macro-val">--g</span>
					</div>
				</div>

                <div class="results-footer">
                    <p>These are baseline estimates. For a custom-built plan tracked and adjusted by me to guarantee your results, <a href="#packages" class="text-link">check out my coaching packages below</a>.</p>
                </div>
			</div>
		</div>
	</div>
</section>

<style>
    .glass-section {
        position: relative;
        background: linear-gradient(to bottom, var(--surface-hover), var(--bg-color));
    }
    
	.bagde-accent {
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
	}

	.tools-desc {
		max-width: 650px;
		margin: 1rem auto;
		color: var(--text-muted);
		font-size: 1.1rem;
		text-align: center;
	}

	.calculator-container {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem;
		border-radius: var(--radius);
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

    @media (min-width: 768px) {
        .calculator-container {
            grid-template-columns: 1fr 1fr;
        }
    }

	.calc-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.input-row {
		display: flex;
		gap: 1rem;
	}

	.input-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex-grow: 1;
	}

	label {
		font-weight: 600;
		color: var(--text-main);
		font-size: 0.95rem;
	}

	input, select {
		width: 100%;
		padding: 12px 16px;
		background: rgba(0, 0, 0, 0.5);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		color: #fff;
		font-family: inherit;
		outline: none;
		transition: border-color var(--transition);
	}

	input:focus, select:focus {
		border-color: var(--accent-color);
	}
    
    select option {
        background: var(--surface-color);
        color: #fff;
    }

	.calculate-btn {
		margin-top: 1rem;
		width: 100%;
		padding: 16px;
		font-size: 1.1rem;
	}

	.results-panel {
		background: rgba(0, 0, 0, 0.4);
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
        border: 1px solid rgba(255,255,255,0.05);
	}
    
    .results-panel.hidden {
        opacity: 0.3;
        pointer-events: none;
        filter: grayscale(100%);
    }

	.results-title {
		font-size: 1.4rem;
		margin-bottom: 1.5rem;
		color: var(--text-muted);
	}

	.calories-result {
		margin-bottom: 2rem;
	}

	.big-number {
		font-size: 3.5rem;
		font-weight: 800;
		color: var(--accent-color);
		line-height: 1;
	}

	.calories-result .label {
		display: block;
		font-size: 1.1rem;
		color: var(--text-muted);
		margin-top: 0.5rem;
	}

	.macros-row {
		display: flex;
		width: 100%;
		gap: 1rem;
		justify-content: center;
	}

	.macro-box {
		flex: 1;
		background: rgba(255, 255, 255, 0.05);
		padding: 1rem 0.5rem;
		border-radius: 8px;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
    
    .macro-box.protein { border-top: 3px solid #ff4d4d; }
    .macro-box.carbs { border-top: 3px solid #4da6ff; }
    .macro-box.fats { border-top: 3px solid #ffb34d; }

	.macro-label {
		font-size: 0.85rem;
		text-transform: uppercase;
		color: var(--text-muted);
		letter-spacing: 1px;
	}

	.macro-val {
		font-size: 1.3rem;
		font-weight: 700;
		color: #fff;
	}
    
    .results-footer {
        margin-top: 2rem;
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.5;
    }
    
    .text-link {
        color: var(--accent-color);
        text-decoration: underline;
    }

	@media (max-width: 600px) {
		.input-row {
			flex-direction: column;
		}
		.calculator-container {
			padding: 2rem 1.5rem;
		}
	}
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('macro-form');
        const resultsPanel = document.getElementById('results-panel');
        
        if(form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                
                // Get values
                const gender = document.getElementById('gender').value;
                const age = parseFloat(document.getElementById('age').value);
                const weight = parseFloat(document.getElementById('weight').value);
                const height = parseFloat(document.getElementById('height').value);
                const activity = parseFloat(document.getElementById('activity').value);
                const goal = document.getElementById('goal').value;
                
                // Calculate BMR (Mifflin-St Jeor Equation)
                let bmr = (10 * weight) + (6.25 * height) - (5 * age);
                if (gender === 'male') {
                    bmr += 5;
                } else {
                    bmr -= 161;
                }
                
                // Calculate TDEE
                let tdee = bmr * activity;
                
                // Adjust for goal
                if (goal === 'cut') {
                    tdee -= 500; // standard 500 kcal deficit
                } else if (goal === 'bulk') {
                    tdee += 300; // standard 300 kcal surplus
                }
                
                tdee = Math.round(tdee);
                
                // Macro split (Standard balanced: 30% protein, 40% carbs, 30% fats)
                const proteinCalories = tdee * 0.30;
                const carbCalories = tdee * 0.40;
                const fatCalories = tdee * 0.30;
                
                const proteinGrams = Math.round(proteinCalories / 4);
                const carbGrams = Math.round(carbCalories / 4);
                const fatGrams = Math.round(fatCalories / 9);
                
                // Animate numbers
                animateValue('res-calories', 0, tdee, 1000);
                setTimeout(() => {
                    document.getElementById('res-protein').textContent = proteinGrams + 'g';
                    document.getElementById('res-carbs').textContent = carbGrams + 'g';
                    document.getElementById('res-fats').textContent = fatGrams + 'g';
                }, 500);
                
                resultsPanel.classList.remove('hidden');
            });
        }
        
        function animateValue(id, start, end, duration) {
            const obj = document.getElementById(id);
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                obj.innerHTML = Math.floor(progress * (end - start) + start);
                if (progress < 1) {
                    window.requestAnimationFrame(step);
                }
            };
            window.requestAnimationFrame(step);
        }
    });
</script>
