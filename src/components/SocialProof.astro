---
---
<div id="social-proof-toast" class="social-proof-toast" aria-hidden="true">
	<div class="toast-content">
		<div class="toast-icon">🔥</div>
		<div class="toast-text">
			<p class="toast-title" id="toast-title">Someone just booked!</p>
			<small class="toast-time">Just now</small>
		</div>
	</div>
</div>

<style>
	.social-proof-toast {
		position: fixed;
		bottom: 110px;
		left: 30px;
		background: rgba(13, 14, 18, 0.95);
		border: 1px solid rgba(226, 255, 0, 0.3);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 0.8rem 1.2rem;
		border-radius: 12px;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 15px rgba(226, 255, 0, 0.1);
		z-index: 998;
		transform: translateY(30px);
		opacity: 0;
		pointer-events: none;
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
        max-width: 300px;
	}

	.social-proof-toast.show {
		transform: translateY(0);
		opacity: 1;
	}

	.toast-content {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.toast-icon {
		font-size: 1.5rem;
        background: rgba(226, 255, 0, 0.1);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
	}

	.toast-text {
		display: flex;
		flex-direction: column;
	}

	.toast-title {
		margin: 0;
		color: #fff;
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.toast-time {
		color: var(--text-muted, #888);
		font-size: 0.75rem;
		margin-top: 2px;
	}

    @media (max-width: 768px) {
        .social-proof-toast {
            top: 110px;      /* Safely below both marquee (44px) and navbar (60px) when at top of page */
            bottom: auto;
            left: 50%;
            transform: translate(-50%, -30px);
            width: 90%;
            max-width: 350px;
        }
        .social-proof-toast.show {
            transform: translate(-50%, 0);
        }
    }
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		const toast = document.getElementById('social-proof-toast');
		const title = document.getElementById('toast-title');
		if (!toast || !title) return;

        const STORAGE_KEY = 'salakawy_social_proof_queue_v1';

        function generateQueue() {
            const femaleNames = ["Laila", "Nour", "Salma", "Hana", "Malak", "Mayar", "Nadine", "Yasmine", "Amina", "Noha", "Habiba", "Zeina", "Haidy", "Nourhan", "Jana", "Retaj", "Tala", "Tia", "Mariam", "Dina", "Sarah", "Layla", "Fatma", "Reem", "Rawan", "Sama", "Maya", "Lina", "Gana", "Hagar", "Aya", "Ola", "Engy", "Rania", "Mona", "Abeer", "Shahd", "Farah", "Judy"];
            const maleNames = ["Ahmed", "Omar", "Youssef", "Aly", "Tarek", "Karim", "Seif", "Marwan", "Adam", "Ziad", "Yassin", "Amr", "Hazem", "Ismail", "Hussein", "Yehia", "Hassan", "Kamal", "Sherif", "Maged", "Raafat", "Khaled", "Mostafa", "Mahmoud", "Ezz", "Adel"];
            
            const lastNames = ["Shenawy", "Radwan", "Osman", "El-Masry", "Fahmy", "Tawfik", "Mansour", "El-Sawy", "Kamel", "El-Khatib", "Rostom", "El-Gendy", "Soliman", "Nassar", "Abdel-Rahman", "El-Sayed", "Badawi", "Fouad", "Wagdi", "Rizk", "El-Wakeel", "El-Maghraby", "Bahaa", "Allam", "El-Sherbiny", "Shafik", "El-Shazly", "Abou-Zeid", "Ghallab"];
            
            const egyptLocations = ["Zamalek", "Heliopolis", "Maadi", "Sheikh Zayed", "New Cairo", "Garden City", "Dokki", "Mohandeseen", "Agouza", "Alexandria", "Giza", "Cairo", "Dahab", "Hurghada", "Sheraton", "Katameya"];
            const otherArabCountries = ["Saudi Arabia", "UAE", "Kuwait", "Qatar", "Bahrain", "Oman", "Jordan", "Lebanon"];
            
            const actions = [
                "booked the Silver Package", "joined the VIP Transformation", "grabbed the 3-Month Plan",
                "started their 1-Month Diet journey", "upgraded to Gold", "booked the Support Team Package",
                "snagged a Premium spot", "secured the 6-Month Intensive Plan", "joined the Elite Coaching Program",
                "purchased the Custom Workout Protocol", "started the Full Body Recomp Plan", "booked the Monthly Platinum Package", "joined the 90-Day Challenge",
                "crushed their 10kg goal and renewed", "broke their plateau with the VIP Plan", "joined the exclusive coaching matrix"
            ];
            const emojis = ["🔥", "💎", "🏆", "🚀", "⭐", "👑", "✨", "💥", "🦍", "🎯", "🥗"];

            const queue = [];
            for (let i = 0; i < 150; i++) {
                // Gender Bias: ~65% Female
                const isFemale = Math.random() < 0.65;
                const fn = isFemale 
                    ? femaleNames[Math.floor(Math.random() * femaleNames.length)]
                    : maleNames[Math.floor(Math.random() * maleNames.length)];
                
                const ln = lastNames[Math.floor(Math.random() * lastNames.length)];
                
                // Country Ratio: 80% Egypt, 20% Other Arab
                const isEgypt = Math.random() < 0.8;
                const loc = isEgypt
                    ? egyptLocations[Math.floor(Math.random() * egyptLocations.length)]
                    : otherArabCountries[Math.floor(Math.random() * otherArabCountries.length)];
                
                const act = actions[Math.floor(Math.random() * actions.length)];
                const icon = emojis[Math.floor(Math.random() * emojis.length)];

                let textTemplate = Math.random();
                let text = "";
                
                // Subtlety: Vary the templates
                if (isEgypt) {
                    if (textTemplate < 0.4) {
                        text = `${fn} ${ln} from ${loc} just ${act}! ${icon}`;
                    } else if (textTemplate < 0.7) {
                        text = `${fn} from ${loc} just ${act}! ${icon}`;
                    } else {
                        text = `${fn} ${ln} just ${act}! ${icon}`;
                    }
                } else {
                    // For other countries, usually just Name + Country looks more natural
                    if (textTemplate < 0.6) {
                        text = `${fn} from ${loc} just ${act}! ${icon}`;
                    } else {
                        text = `${fn} ${ln} from ${loc} just ${act}! ${icon}`;
                    }
                }

                queue.push({ text, icon });
            }

            // Fisher-Yates array shuffle for total randomness
            for (let i = queue.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [queue[i], queue[j]] = [queue[j], queue[i]];
            }

            return queue;
        }

        let eventQueue = [];
        try {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored) {
                eventQueue = JSON.parse(stored);
            } else {
                eventQueue = generateQueue();
                localStorage.setItem(STORAGE_KEY, JSON.stringify(eventQueue));
            }
        } catch (e) {
            // Fallback if local storage restricted
            eventQueue = generateQueue();
        }

        const initialDelay = Math.random() * 15000 + 10000; // 10s to 25s before first
        
		function triggerToast() {
			if (window.location.pathname.includes('contact')) return; // Don't block the checkout
            
            // If the user has exhausted all 150 toasts across sessions, don't show anymore
            if (!eventQueue || eventQueue.length === 0) return;

			const currentEvent = eventQueue.shift(); // Remove the first item from the queue
            
            // Re-save the trimmed queue to localStorage so they never see it again
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(eventQueue));
            } catch(e) {}

			title.innerText = currentEvent.text;
            const iconEl = toast.querySelector('.toast-icon');
            if (iconEl) iconEl.innerHTML = currentEvent.icon;

			toast.classList.add('show');

			// Hide after 4.5 seconds
			setTimeout(() => {
				toast.classList.remove('show');
			}, 4500);

			// Schedule next randomly between 45 seconds to 60 seconds
			setTimeout(triggerToast, Math.random() * 15000 + 45000);
		}

		setTimeout(triggerToast, initialDelay);
	});
</script>
