---
---
<div id="social-proof-toast" class="social-proof-toast" aria-hidden="true">
	<div class="toast-content">
		<div class="toast-icon">🔥</div>
		<div class="toast-text">
			<p class="toast-title" id="toast-title">Someone just booked!</p>
			<small class="toast-time">Just now</small>
		</div>
	</div>
</div>

<style>
	.social-proof-toast {
		position: fixed;
		bottom: 110px;
		left: 30px;
		background: rgba(13, 14, 18, 0.95);
		border: 1px solid rgba(226, 255, 0, 0.3);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 0.8rem 1.2rem;
		border-radius: 12px;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 15px rgba(226, 255, 0, 0.1);
		z-index: 998;
		transform: translateY(30px);
		opacity: 0;
		pointer-events: none;
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
        max-width: 300px;
	}

	.social-proof-toast.show {
		transform: translateY(0);
		opacity: 1;
	}

	.toast-content {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.toast-icon {
		font-size: 1.5rem;
        background: rgba(226, 255, 0, 0.1);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
	}

	.toast-text {
		display: flex;
		flex-direction: column;
	}

	.toast-title {
		margin: 0;
		color: #fff;
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.toast-time {
		color: var(--text-muted, #888);
		font-size: 0.75rem;
		margin-top: 2px;
	}

    @media (max-width: 768px) {
        .social-proof-toast {
            top: 80px;      /* Show at the top on mobile so it doesn't block the bottom nav/chat */
            bottom: auto;
            left: 50%;
            transform: translate(-50%, -30px);
            width: 90%;
            max-width: 350px;
        }
        .social-proof-toast.show {
            transform: translate(-50%, 0);
        }
    }
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		const toast = document.getElementById('social-proof-toast');
		const title = document.getElementById('toast-title');
		if (!toast || !title) return;

		const events = [
			{ text: "Ahmed from Cairo just booked the Silver Package! 🔥", icon: "💎" },
			{ text: "Sara just crushed her 10kg goal and beat insulin resistance! 🎉", icon: "🏆" },
			{ text: "A user from Riyadh joined the Platinum VIP Transformation!", icon: "🔥" },
			{ text: "Mahmoud lost 41kg and transformed his life completely! 💪", icon: "🚀" },
			{ text: "Someone in Alexandria just grabbed the 3-Month Plan!", icon: "⭐" },
			{ text: "A new client from Giza just started their 1-Month Diet journey! 🥗", icon: "🟢" },
			{ text: "Marwan hit his 90-day goal and upgraded to Gold! 👑", icon: "👑" },
			{ text: "Someone from Dubai just booked the Support Team Package!", icon: "✨" },
			{ text: "Youssef broke his plateau and dropped another 3kg! 💥", icon: "📉" },
			{ text: "A client from Mansoura started the Silver Plan today.", icon: "💎" },
			{ text: "Nour recently reversed her PCOS symptoms safely! 🌸", icon: "🌸" },
			{ text: "Someone from Tanta just booked the 6-Month Plan!", icon: "🔥" },
			{ text: "Omar packed on 5kg of clean muscle in 12 weeks! 🦍", icon: "🦍" },
			{ text: "A user from Jeddah just snagged a Platinum spot!", icon: "💎" },
			{ text: "Farida finally conquered her midnight sugar cravings! 🍫", icon: "🎯" }
		];

        const initialDelay = Math.random() * 15000 + 10000; // 10s to 25s before first
        
		function triggerToast() {
			if (window.location.pathname.includes('contact')) return; // Don't block the checkout

			const randomEvent = events[Math.floor(Math.random() * events.length)];
			title.innerText = randomEvent.text;
            const iconEl = toast.querySelector('.toast-icon');
            if (iconEl) iconEl.innerHTML = randomEvent.icon;

			toast.classList.add('show');

			// Hide after 4 seconds
			setTimeout(() => {
				toast.classList.remove('show');
			}, 4500);

			// Schedule next randomly between 45 seconds to 60 seconds
			setTimeout(triggerToast, Math.random() * 15000 + 45000);
		}

		setTimeout(triggerToast, initialDelay);
	});
</script>
