<section id="struggles-preview" class="section struggles-bg">
	<div class="container">
		<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 3rem;">
			<h2 class="section-title fade-in-up" style="margin-bottom: 0;">Are you struggling with...</h2>
			<span class="badge fade-in-up" style="margin-bottom: 0;">Identify Your Obstacles</span>
			<p class="trans-desc fade-in-up delay-100" style="margin-top: 0; text-align: center;">We know how hard it can be. From stressful emotional eating to stubborn belly fat, you must <strong>stop making excuses</strong>. Identify what's holding you back and <strong>commit to overcoming it today</strong> with Coach Salakawy.</p>
		</div>

		<div class="struggles-grid fade-in-up delay-200">
			<a href="/common-challenges#low-motivation" style="text-decoration: none;" class="struggle-card glass-panel glass-panel-hover">
				<div class="struggle-icon">🔥</div>
				<h3 class="struggle-title">Low Motivation</h3>
			</a>
			<a href="/common-challenges#sugar-cravings" style="text-decoration: none;" class="struggle-card glass-panel glass-panel-hover">
				<div class="struggle-icon">🍰</div>
				<h3 class="struggle-title">Sugar Cravings</h3>
			</a>
			<a href="/common-challenges#emotional-eating" style="text-decoration: none;" class="struggle-card glass-panel glass-panel-hover">
				<div class="struggle-icon">🍔</div>
				<h3 class="struggle-title">Emotional Eating</h3>
			</a>
			<a href="/common-challenges#weight-plateau" style="text-decoration: none;" class="struggle-card glass-panel glass-panel-hover">
				<div class="struggle-icon">📉</div>
				<h3 class="struggle-title">Weight Plateau</h3>
			</a>
		</div>

		<div style="text-align: center; margin-top: 3rem;" class="fade-in-up delay-300">
			<a href="/common-challenges" class="btn btn-primary">See All Struggles & Solutions</a>
		</div>
	</div>
</section>

<style>
	.struggles-bg {
		background-color: var(--bg-color);
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	.trans-desc {
		max-width: 600px;
		margin: 1rem auto 0 auto;
		color: var(--text-muted);
		font-size: 1.1rem;
	}

	.struggles-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.struggle-card {
		background: var(--surface-color);
		border-radius: var(--radius);
		padding: 2rem 1.5rem;
		text-align: center;
		transition: transform var(--transition);
		border: 1px solid rgba(255, 255, 255, 0.05);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	.struggle-card:hover {
		transform: translateY(-5px);
		border-color: rgba(255, 255, 0, 0.2);
	}

	.struggle-icon {
		font-size: 3rem;
		line-height: 1;
	}

	.struggle-title {
		color: var(--text-main);
		font-size: 1.25rem;
		margin: 0;
		text-decoration: none;
	}
</style>
