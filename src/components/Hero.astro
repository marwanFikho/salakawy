---
import fs from 'fs';
import path from 'path';
import { getContent, getVal } from '../backend/content';

const c = getContent('homepage');

const picsDir = path.join(process.cwd(), 'public', 'Salakawy Pics');
let heroImages = [];
try {
	if (fs.existsSync(picsDir)) {
		heroImages = fs.readdirSync(picsDir)
			.filter(file => /\.(jpg|jpeg|png|webp)$/i.test(file))
			.map(file => `/Salakawy Pics/${encodeURIComponent(file)}`);
	}
} catch (e) {
	console.error('Error reading Salakawy Pics', e);
}

// Shuffle original images
let shuffledImages = [...heroImages];
for (let i = shuffledImages.length - 1; i > 0; i--) {
	const j = Math.floor(Math.random() * (i + 1));
	[shuffledImages[i], shuffledImages[j]] = [shuffledImages[j], shuffledImages[i]];
}

// We only use each image exactly once as requested
let displayImages = [...shuffledImages];

// Split into 4 distinct columns for the seamless waterfall
const columns = [[], [], [], []];
displayImages.forEach((src, i) => {
	columns[i % 4].push(src);
});
---
<section id="hero" class="hero">
	<div class="hero-bg-collage">
		{columns.map((col, idx) => (
			<div class="masonry-column" style={`animation-delay: -${idx * 5}s`}>
				<div class="masonry-track">
					<div class="masonry-set">
						{col.map(src => (
							<img 
								src={src.replace(/'/g, "%27")} 
								class="collage-item" 
								alt="Transformation background"
								loading="lazy"
							/>
						))}
					</div>
					<!-- Duplicate set for seamless looping -->
					<div class="masonry-set">
						{col.map(src => (
							<img 
								src={src.replace(/'/g, "%27")} 
								class="collage-item" 
								alt="Transformation background"
								loading="lazy"
							/>
						))}
					</div>
				</div>
			</div>
		))}
	</div>
	<div class="hero-overlay"></div>
	<div class="container hero-content">
		<div class="hero-text fade-in-up">
			<div class="badge fade-in-up" data-editable="homepage:hero.badge" set:html={getVal(c, 'hero.badge', '🔥 Salakawy Coaching')} />
			<h1 class="hero-title fade-in-up delay-100">
				<span class="highlight" data-editable="homepage:hero.highlight" set:html={getVal(c, 'hero.highlight', 'Transform')} /> <span data-editable="homepage:hero.title" set:html={getVal(c, 'hero.title', 'Your Body.<br />Transform Your Life.')} />
			</h1>
			<p class="hero-subtitle delay-100" data-editable="homepage:hero.desc" set:html={getVal(c, 'hero.desc', 'I don’t just sell a simple diet plan. I sell a mindset. <strong>Stop saying you\'ll start tomorrow</strong> and <strong>start acting today</strong>. A generic routine you can get anywhere, but if you are ready to hit the gym and <strong>build the body you deserve</strong>, this is your only stop.')} />
			<div class="hero-actions delay-200">
				<a href="/contact-us" class="btn btn-primary" data-editable="homepage:hero.btn1" set:html={getVal(c, 'hero.btn1', 'Start Your Journey Now')} />
				<a href="#packages" class="btn btn-outline" data-editable="homepage:hero.btn2" set:html={getVal(c, 'hero.btn2', 'Explore Packages')} />
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background-color: #000;
		overflow: hidden;
	}

	.hero-bg-collage {
		position: absolute;
		top: -5%; left: -5%; width: 110%; height: 110%; 
		display: flex;
		gap: 15px;
		opacity: 1.0; /* Full opacity on the container to maximize brightness */
		z-index: 0;
		transform: rotate(-2deg) scale(1.05); /* Dynamic diagonal angle */
		overflow: hidden; /* Hide overflow outside the skewed container */
	}

	.masonry-column {
		flex: 1;
		display: flex;
		flex-direction: column;
		/* Optional: give each column a slightly different speed or offset if desired, 
		   but kept simple to ensure constant waterfall speed */
	}

	.masonry-track {
		display: flex;
		flex-direction: column;
		gap: 15px;
		/* Linear animation for constant waterfall speed */
		animation: waterfall 50s linear infinite;
	}

	.masonry-set {
		display: flex;
		flex-direction: column;
		gap: 15px;
	}

	@keyframes waterfall {
		/* Start shifted up by exactly one set (50% of track + half the middle gap) */
		0% { transform: translateY(calc(-50% - 7.5px)); }
		100% { transform: translateY(0%); }
	}

	.collage-item {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 8px; /* Soft edges since they are full images now */
		filter: grayscale(10%) sepia(5%) hue-rotate(-10deg) contrast(1.1) brightness(1.2);
		/* Note: We remove the pulse animation on individual items here because we are animating the whole container now. Too much animation can cause lag. */
		opacity: 0.9;
		box-shadow: 0 5px 15px rgba(0,0,0,0.5); /* Drop shadow instead of inset since it's an img tag */
	}

	.hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		/* Cinematic vignette: very transparent in the center to let bright photos through */
		background: radial-gradient(circle at center, rgba(13, 14, 18, 0.1) 0%, rgba(13, 14, 18, 0.6) 60%, rgba(13, 14, 18, 0.95) 100%);
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding-top: 104px; /* offset for nav + new top marquee */
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		width: 100%;
	}

	.hero-text {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		letter-spacing: 1px;
		text-transform: uppercase;
	}

	.hero-title {
		font-size: 4.5rem;
		margin-bottom: 1.5rem;
		letter-spacing: -1px;
		text-shadow: 0 4px 20px rgba(0,0,0,0.8);
	}

	.highlight {
		color: var(--accent-color);
	}

	.hero-subtitle {
		font-size: 1.25rem;
		color: var(--text-muted);
		margin-bottom: 2.5rem;
		font-weight: 300;
		text-shadow: 0 2px 10px rgba(0,0,0,0.8);
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-outline {
		background: transparent;
		color: var(--text-main);
		border: 1px solid rgba(255, 255, 255, 0.3);
	}

	.btn-outline:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--text-main);
	}

	@media (max-width: 768px) {
		/* Keep 4 columns on mobile so it looks like a texture */
		.hero-title {
			font-size: 3rem;
		}
		
		.hero-content {
			padding-bottom: 3rem; /* Extra space before the marquee on mobile */
		}
		
		.hero-actions {
			flex-direction: column;
		}

		.hero-overlay {
			/* Oval vignette for mobile */
			background: radial-gradient(ellipse at center, rgba(13, 14, 18, 0.2) 0%, rgba(13, 14, 18, 0.7) 60%, rgba(13, 14, 18, 0.95) 100%);
		}
	}

	}
</style>
