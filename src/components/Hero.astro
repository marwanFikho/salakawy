---
import fs from 'fs';
import path from 'path';

const picsDir = path.join(process.cwd(), 'public', 'Salakawy Pics');
let heroImages = [];
try {
	if (fs.existsSync(picsDir)) {
		heroImages = fs.readdirSync(picsDir)
			.filter(file => /\.(jpg|jpeg|png|webp)$/i.test(file))
			.map(file => `/Salakawy Pics/${encodeURIComponent(file)}`);
	}
} catch (e) {
	console.error('Error reading Salakawy Pics', e);
}

// Shuffle original images
let shuffledImages = [...heroImages];
for (let i = shuffledImages.length - 1; i > 0; i--) {
	const j = Math.floor(Math.random() * (i + 1));
	[shuffledImages[i], shuffledImages[j]] = [shuffledImages[j], shuffledImages[i]];
}

// Ensure we have enough to fill a massive desktop grid (e.g., 60-100 cells)
let extendedImages = [];
while (extendedImages.length < 80 && shuffledImages.length > 0) {
	extendedImages = extendedImages.concat(shuffledImages);
}

// Add a slight randomization to the extended array
extendedImages.sort(() => Math.random() - 0.5);
---
<section id="hero" class="hero">
	<div class="hero-bg-collage">
		{extendedImages.map((src, i) => (
			<div 
				class="collage-item" 
				style={`background-image: url('${src.replace(/'/g, "%27")}'); animation-delay: ${(Math.random() * 5).toFixed(2)}s;`}
			></div>
		))}
	</div>
	<div class="hero-overlay"></div>
	<div class="container hero-content">
		<div class="hero-text fade-in-up">
			<span class="badge">Changing Mindsets</span>
			<h1 class="hero-title">
				Real <span class="highlight">Transformation</span>. <br />
				Not Just a Diet Plan.
			</h1>
			<p class="hero-subtitle delay-100">
				I don’t just sell a simple diet plan. I sell a mindset. <strong>Stop saying you'll start tomorrow</strong> and <strong>start acting today</strong>. A generic routine you can get anywhere, but if you are ready to hit the gym and <strong>build the body you deserve</strong>, this is your only stop.
			</p>
			<div class="hero-actions delay-200">
				<a href="/contact-us" class="btn btn-primary">Start Your Journey Now</a>
				<a href="#packages" class="btn btn-outline">Explore Packages</a>
			</div>
		</div>
	</div>
	
	<!-- Aggressive Scrolling Marquee -->
	<div class="marquee-container">
		<div class="marquee-content" aria-hidden="true">
			<span class="marquee-text">🔥 NO EXCUSES</span>
			<span class="marquee-text">💪 GUARANTEED RESULTS</span>
			<span class="marquee-text">🔥 STOP PROCRASTINATING</span>
			<span class="marquee-text">🏆 OVER 11000+ TRANSFORMED</span>
			<span class="marquee-text">🚀 YOU ARE NEXT</span>
			<span class="marquee-text">⚡ CLAIM YOUR BODY TODAY</span>
			<!-- duplicate for seamless loop -->
			<span class="marquee-text">🔥 NO EXCUSES</span>
			<span class="marquee-text">💪 GUARANTEED RESULTS</span>
			<span class="marquee-text">🔥 STOP PROCRASTINATING</span>
			<span class="marquee-text">🏆 OVER 11000+ TRANSFORMED</span>
			<span class="marquee-text">🚀 YOU ARE NEXT</span>
			<span class="marquee-text">⚡ CLAIM YOUR BODY TODAY</span>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background-color: #000;
		overflow: hidden;
	}

	.hero-bg-collage {
		position: absolute;
		top: -10%; left: -10%; width: 120%; height: 120%; /* Bleed to allow seamless cover */
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		grid-auto-rows: 180px;
		opacity: 0.45; /* Soften the background to not overpower the text */
		z-index: 0;
		transform: rotate(-3deg) scale(1.05); /* Dynamic diagonal angle */
	}

	.collage-item {
		background-size: cover;
		background-position: center;
		filter: grayscale(60%) sepia(20%) hue-rotate(-20deg) contrast(1.1);
		animation: pulseOpacity 6s infinite alternate ease-in-out;
		opacity: 0.6;
		box-shadow: inset 0 0 20px rgba(0,0,0,0.8); /* Darken edges to blend them together */
	}

	@keyframes pulseOpacity {
		0% { opacity: 0.3; filter: grayscale(80%) brightness(0.8); }
		100% { opacity: 0.9; filter: grayscale(20%) brightness(1.2); }
	}

	.hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: linear-gradient(90deg, rgba(13, 14, 18, 0.95) 0%, rgba(13, 14, 18, 0.7) 50%, rgba(13, 14, 18, 0.4) 100%);
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding-top: 80px; /* offset for nav */
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		width: 100%;
	}

	.hero-text {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		letter-spacing: 1px;
		text-transform: uppercase;
	}

	.hero-title {
		font-size: 4.5rem;
		margin-bottom: 1.5rem;
		letter-spacing: -1px;
	}

	.highlight {
		color: var(--accent-color);
	}

	.hero-subtitle {
		font-size: 1.25rem;
		color: var(--text-muted);
		margin-bottom: 2.5rem;
		font-weight: 300;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-outline {
		background: transparent;
		color: var(--text-main);
		border: 1px solid rgba(255, 255, 255, 0.3);
	}

	.btn-outline:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--text-main);
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 3rem;
		}
		
		.hero-content {
			padding-bottom: 3rem; /* Extra space before the marquee on mobile */
		}
		
		.hero-actions {
			flex-direction: column;
		}

		.hero-overlay {
			background: linear-gradient(180deg, rgba(13, 14, 18, 0.8) 0%, rgba(13, 14, 18, 0.95) 100%);
		}
	}

	/* Marquee Styles */
	.marquee-container {
		position: relative;
		width: 100%;
		background: var(--accent-color);
		overflow: hidden;
		white-space: nowrap;
		padding: 12px 0;
		border-top: 1px solid rgba(0,0,0,0.2);
		z-index: 10;
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}
	.marquee-content {
		display: inline-block;
		animation: marquee-scroll 18s linear infinite;
	}
	.marquee-text {
		font-size: 1.15rem;
		font-weight: 800;
		color: #000;
		margin: 0 20px;
		letter-spacing: 0.5px;
	}
	@keyframes marquee-scroll {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
</style>
