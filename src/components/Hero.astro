---
---
<section id="hero" class="hero">
	<div class="hero-overlay"></div>
	<div class="container hero-content">
		<div class="hero-text fade-in-up">
			<span class="badge">Premium Coaching</span>
			<h1 class="hero-title">
				Real <span class="highlight">Transformation</span>. <br />
				Not Just a Diet Plan.
			</h1>
			<p class="hero-subtitle delay-100">
				I don’t sell a simple diet plan or workout routine. I sell a mindset and lifestyle you can follow for life. A diet plan you can get anywhere, but what I offer is the real transformation.
			</p>
			<div class="hero-actions delay-200">
				<a href="https://wa.me/201217720267" class="btn btn-primary" target="_blank" rel="noopener">Start Your Journey Now</a>
				<a href="#packages" class="btn btn-outline">Explore Packages</a>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		background: url('/hero_bg.png') center/cover no-repeat;
		overflow: hidden;
	}

	.hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: linear-gradient(90deg, rgba(13, 14, 18, 0.95) 0%, rgba(13, 14, 18, 0.7) 50%, rgba(13, 14, 18, 0.4) 100%);
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding-top: 80px; /* offset for nav */
	}

	.hero-text {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		letter-spacing: 1px;
		text-transform: uppercase;
	}

	.hero-title {
		font-size: 4.5rem;
		margin-bottom: 1.5rem;
		letter-spacing: -1px;
	}

	.highlight {
		color: var(--accent-color);
	}

	.hero-subtitle {
		font-size: 1.25rem;
		color: var(--text-muted);
		margin-bottom: 2.5rem;
		font-weight: 300;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-outline {
		background: transparent;
		color: var(--text-main);
		border: 1px solid rgba(255, 255, 255, 0.3);
	}

	.btn-outline:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--text-main);
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 3rem;
		}
		
		.hero-actions {
			flex-direction: column;
		}

		.hero-overlay {
			background: linear-gradient(180deg, rgba(13, 14, 18, 0.8) 0%, rgba(13, 14, 18, 0.95) 100%);
		}
	}
</style>
