<section id="hero" class="hero">
	<div class="hero-overlay"></div>
	<div class="container hero-content">
		<div class="hero-text fade-in-up">
			<span class="badge">Changing Mindsets</span>
			<h1 class="hero-title">
				Real <span class="highlight">Transformation</span>. <br />
				Not Just a Diet Plan.
			</h1>
			<p class="hero-subtitle delay-100">
				I don’t just sell a simple diet plan. I sell a mindset. <strong>Stop saying you'll start tomorrow</strong> and <strong>start acting today</strong>. A generic routine you can get anywhere, but if you are ready to hit the gym and <strong>build the body you deserve</strong>, this is your only stop.
			</p>
			<div class="hero-actions delay-200">
				<a href="/contact-us" class="btn btn-primary">Start Your Journey Now</a>
				<a href="#packages" class="btn btn-outline">Explore Packages</a>
			</div>
		</div>
	</div>
</section>

<!-- Aggressive Scrolling Marquee -->
<div class="marquee-container">
    <div class="marquee-content" aria-hidden="true">
        <span class="marquee-text">🔥 NO EXCUSES</span>
        <span class="marquee-text">💪 GUARANTEED RESULTS</span>
        <span class="marquee-text">🔥 STOP PROCRASTINATING</span>
        <span class="marquee-text">🏆 OVER 11000+ TRANSFORMED</span>
        <span class="marquee-text">🚀 YOU ARE NEXT</span>
        <span class="marquee-text">⚡ CLAIM YOUR BODY TODAY</span>
        <!-- duplicate for seamless loop -->
        <span class="marquee-text">🔥 NO EXCUSES</span>
        <span class="marquee-text">💪 GUARANTEED RESULTS</span>
        <span class="marquee-text">🔥 STOP PROCRASTINATING</span>
        <span class="marquee-text">🏆 OVER 11000+ TRANSFORMED</span>
        <span class="marquee-text">🚀 YOU ARE NEXT</span>
        <span class="marquee-text">⚡ CLAIM YOUR BODY TODAY</span>
    </div>
</div>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		background: url('/hero_bg.png') center/cover no-repeat;
		overflow: hidden;
	}

	.hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: linear-gradient(90deg, rgba(13, 14, 18, 0.95) 0%, rgba(13, 14, 18, 0.7) 50%, rgba(13, 14, 18, 0.4) 100%);
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding-top: 80px; /* offset for nav */
	}

	.hero-text {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(255, 255, 0, 0.1);
		color: var(--accent-color);
		border: 1px solid rgba(255, 255, 0, 0.3);
		border-radius: 30px;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		letter-spacing: 1px;
		text-transform: uppercase;
	}

	.hero-title {
		font-size: 4.5rem;
		margin-bottom: 1.5rem;
		letter-spacing: -1px;
	}

	.highlight {
		color: var(--accent-color);
	}

	.hero-subtitle {
		font-size: 1.25rem;
		color: var(--text-muted);
		margin-bottom: 2.5rem;
		font-weight: 300;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-outline {
		background: transparent;
		color: var(--text-main);
		border: 1px solid rgba(255, 255, 255, 0.3);
	}

	.btn-outline:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--text-main);
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 3rem;
		}
		
		.hero-actions {
			flex-direction: column;
		}

		.hero-overlay {
			background: linear-gradient(180deg, rgba(13, 14, 18, 0.8) 0%, rgba(13, 14, 18, 0.95) 100%);
		}
	}

	/* Marquee Styles */
	.marquee-container {
		background: var(--accent-color);
		overflow: hidden;
		white-space: nowrap;
		padding: 12px 0;
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		border-top: 1px solid rgba(0,0,0,0.2);
		z-index: 10;
		display: flex;
		align-items: center;
	}
	.marquee-content {
		display: inline-block;
		animation: marquee-scroll 18s linear infinite;
	}
	.marquee-text {
		font-size: 1.15rem;
		font-weight: 800;
		color: #000;
		margin: 0 20px;
		letter-spacing: 0.5px;
	}
	@keyframes marquee-scroll {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
</style>
