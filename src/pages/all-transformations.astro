<script>
    document.addEventListener('astro:page-load', () => {

		// ── Age Group Explosion — powered by GSAP ──────────────────
		import('gsap').then(({ gsap }) => {

		const overlay      = document.getElementById('age-explode-overlay');
		const explodeCanvas= document.getElementById('explode-canvas');
		const explodeTitle = document.getElementById('explode-title');
		const compactBtn   = document.getElementById('explode-compact-btn');
		const groupCards   = document.querySelectorAll('.age-group-card:not(.age-group-empty)');

		const HEADER_H = 62;
		let sourceCard = null;
		let sourceRect = null;
		let activeCards = [];

		// Inject hover/drag styles (bypass Astro CSS scoping on JS-created elements)
		if (!document.getElementById('explode-dynamic-styles')) {
			const st = document.createElement('style');
			st.id = 'explode-dynamic-styles';
			st.textContent = [
				'.explode-item-card:hover { border-color: rgba(255,255,0,.5) !important; box-shadow: 0 8px 28px rgba(255,255,0,.25) !important; }',
				'.explode-item-card.is-dragging { cursor: grabbing !important; box-shadow: 0 20px 50px rgba(0,0,0,.9) !important; z-index: 200 !important; }'
			].join('');
			document.head.appendChild(st);
		}

		// ── Drag (synced with GSAP's transform state) ──────────────
		function makeDraggable(el) {
			let dragging = false, startX, startY, startGX, startGY, moved = false;

			function start(cx, cy) {
				dragging = true; moved = false;
				startX = cx; startY = cy;
				startGX = gsap.getProperty(el, 'x');
				startGY = gsap.getProperty(el, 'y');
				el.classList.add('is-dragging');
				gsap.set(el, { zIndex: 100 });
			}
			function move(cx, cy) {
				if (!dragging) return;
				const dx = cx - startX, dy = cy - startY;
				if (Math.abs(dx) > 3 || Math.abs(dy) > 3) moved = true;
				gsap.set(el, { x: startGX + dx, y: startGY + dy });
			}
			function finish() {
				if (!dragging) return;
				dragging = false;
				el._wasMoved = moved;
				el.classList.remove('is-dragging');
				gsap.set(el, { zIndex: '' });
			}

			el.addEventListener('mousedown',  e => { e.preventDefault(); start(e.clientX, e.clientY); });
			window.addEventListener('mousemove', e => move(e.clientX, e.clientY));
			window.addEventListener('mouseup', finish);
			el.addEventListener('touchstart', e => start(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
			el.addEventListener('touchmove',  e => move(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
			el.addEventListener('touchend', finish);
		}

		// ── Open group (EXPLOSION) ─────────────────────────────────
		function openGroup(card) {
			sourceCard = card;
			sourceRect = card.getBoundingClientRect();
			const images = card.dataset.images.split(',');
			const count  = images.length;
			const label  = card.dataset.label || card.dataset.group;

			const isMobile = window.innerWidth < 768;
			const cardW = count === 1 ? (isMobile ? 280 : 500)
			            : count <= 3  ? (isMobile ? 200 : 350)
			            : count <= 6  ? (isMobile ? 160 : 260)
			            :               (isMobile ? 130 : 200);
			const cardH = Math.round(cardW * 1.25); // more portrait aspect for images

			explodeCanvas.innerHTML = '';
			activeCards = [];

			// Jittered grid layout — guaranteed no overlaps
			const canvasW = window.innerWidth;
			const canvasH = window.innerHeight - HEADER_H;
			const gap   = isMobile ? 14 : 36;
			const cellW = cardW + gap;
			const cellH = cardH + gap;
			const cols  = Math.max(1, Math.floor(canvasW / cellW));
			const rows  = Math.max(1, Math.floor(canvasH / cellH));
			// Center the whole grid block on screen
			const offsetX = (canvasW - (cols * cellW - gap)) / 2;
			const offsetY = (canvasH - (rows * cellH - gap)) / 2;

			// Shuffle slots so assignment order looks random
			let slots = [];
			for (let r = 0; r < rows; r++)
				for (let c = 0; c < cols; c++)
					slots.push({ r, c });
			slots.sort(() => Math.random() - 0.5);

			// Source pile center in canvas coords
			const srcCX = sourceRect.left + sourceRect.width  / 2;
			const srcCY = sourceRect.top  + sourceRect.height / 2 - HEADER_H;

			// Show overlay (cards invisible at this point)
			overlay.classList.add('open');
			document.body.style.overflow = 'hidden';

			images.forEach((src, i) => {
				const slot = slots[i % slots.length];
				const jx   = (Math.random() - 0.5) * gap * 0.6;
				const jy   = (Math.random() - 0.5) * gap * 0.6;
				// Final resting position (top-left of card)
				const finalL = offsetX + slot.c * cellW + jx;
				const finalT = offsetY + slot.r * cellH + jy;
				// Final center
				const finalCX = finalL + cardW / 2;
				const finalCY = finalT + cardH / 2;
				// Slight tilt — max ±8°
				const rot = (Math.random() - 0.5) * 16;

				const cardEl = document.createElement('div');
				cardEl.className = 'explode-item-card';
				Object.assign(cardEl.style, {
					position: 'absolute',
					left: finalL + 'px',   // GSAP will offset via transform
					top:  finalT + 'px',
					width:  cardW + 'px',
					height: cardH + 'px',
					borderRadius: Math.round(cardW * 0.05) + 'px',
					overflow: 'hidden',
					border:   '2px solid rgba(255,255,255,0.15)',
					boxShadow:'0 4px 18px rgba(0,0,0,0.65)',
					cursor:   'grab',
					userSelect:'none',
					zIndex:   String(10 + i),
				});

				const img = document.createElement('img');
				Object.assign(img.style, {
					width:'100%', height:'100%', objectFit:'contain',
					display:'block', pointerEvents:'none', backgroundColor: '#000'
				});
				img.src = src;
				cardEl.appendChild(img);
				explodeCanvas.appendChild(cardEl);
				activeCards.push({ el: cardEl, cardW, cardH });

				// GSAP: start collapsed at the source-card center, explode to slot
				gsap.set(cardEl, {
					opacity:  0,
					scale:    0.05,
					rotation: 0,
					x: srcCX - finalCX,  // offset so transform-origin = final center
					y: srcCY - finalCY,
				});

				gsap.to(cardEl, {
					opacity:  1,
					scale:    1,
					rotation: rot,
					x: 0,
					y: 0,
					duration: 0.75,
					delay:    i * 0.07,
					ease:     'back.out(1.6)',
					onComplete: () => makeDraggable(cardEl),
				});

				cardEl.addEventListener('click', () => {
					if (!cardEl._wasMoved) openLightbox(src);
					cardEl._wasMoved = false;
				});
			});

			explodeTitle.textContent = label;
			groupCards.forEach(c => c.classList.remove('active'));
			sourceCard.classList.add('active');
		}

		// ── Compact (implosion back to pile) ───────────────────────
		function closeGroup() {
			if (!activeCards.length || !sourceRect) return;

			const destCX = sourceRect.left + sourceRect.width  / 2;
			const destCY = sourceRect.top  + sourceRect.height / 2 - HEADER_H;

			activeCards.forEach(({ el, cardW, cardH }, i) => {
				// Current card center on screen
				const r    = el.getBoundingClientRect();
				const curCX = r.left + cardW / 2;
				const curCY = r.top  + cardH / 2 - HEADER_H;

				gsap.to(el, {
					x: gsap.getProperty(el, 'x') + (destCX - curCX),
					y: gsap.getProperty(el, 'y') + (destCY - curCY),
					scale:    0.05,
					opacity:  0,
					rotation: 0,
					duration: 0.5,
					delay:    i * 0.03,
					ease:     'power3.in',
				});
			});

			const totalMs = activeCards.length * 30 + 600;
			setTimeout(() => {
				overlay.classList.remove('open');
				document.body.style.overflow = '';
				setTimeout(() => {
					explodeCanvas.innerHTML = '';
					activeCards = [];
					if (sourceCard) sourceCard.classList.remove('active');
					sourceCard = null;
					sourceRect = null;
				}, 400);
			}, totalMs);
		}

		// ── Lightbox ───────────────────────────────────────────────
		const lightbox    = document.getElementById('explode-lightbox');
		const lightboxImg = document.getElementById('explode-lightbox-img');
		function openLightbox(src) { lightboxImg.src = src; lightbox.classList.add('open'); }
		function closeLightbox() {
			lightbox.classList.remove('open');
			setTimeout(() => { lightboxImg.src = ''; }, 300);
		}
		lightbox.addEventListener('click', closeLightbox);

		// ── Attach all handlers ─────────────────────────────────────
		groupCards.forEach(card => card.addEventListener('click', () => openGroup(card)));
		if (compactBtn) compactBtn.addEventListener('click', closeGroup);
		document.addEventListener('keydown', e => {
			if (e.key === 'Escape') {
				if (lightbox.classList.contains('open')) closeLightbox();
				else if (overlay.classList.contains('open')) closeGroup();
			}
		});

		}); // end import('gsap')






        const modal = document.getElementById('gallery-modal');
        const modalImg = document.getElementById('gallery-modal-img');
        const closeBtn = document.querySelector('.close-modal');
        const prevBtn = document.querySelector('.prev-btn');
        const nextBtn = document.querySelector('.next-btn');
        const items = document.querySelectorAll('.masonry-item img');

        if(modal && modalImg && items.length > 0) {
            let currentIndex = 0;
            const imagesSrc = Array.from(items).map(img => img.getAttribute('src'));

            function showImage(index) {
                if (index < 0) index = imagesSrc.length - 1;
                if (index >= imagesSrc.length) index = 0;
                currentIndex = index;
                modalImg.setAttribute('src', imagesSrc[currentIndex]);
            }

            items.forEach((item, index) => {
                item.closest('.masonry-item').addEventListener('click', () => {
                    showImage(index);
                    modal.classList.add('show');
                    document.body.style.overflow = 'hidden';
                });
            });

            closeBtn.addEventListener('click', () => {
                modal.classList.remove('show');
                document.body.style.overflow = '';
            });

            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.remove('show');
                    document.body.style.overflow = '';
                }
            });

            prevBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                showImage(currentIndex - 1);
            });

            nextBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                showImage(currentIndex + 1);
            });

            // Keyboard navigation
            document.addEventListener('keydown', (e) => {
                if(modal.classList.contains('show')) {
                    if (e.key === 'Escape') closeBtn.click();
                    if (e.key === 'ArrowLeft') prevBtn.click();
                    if (e.key === 'ArrowRight') nextBtn.click();
                }
            });

            // Touch Swipe Support
            let touchStartX = 0;
            let touchEndX = 0;

            modalImg.addEventListener('touchstart', (e) => {
                touchStartX = e.changedTouches[0].screenX;
            }, {passive: true});

            modalImg.addEventListener('touchend', (e) => {
                touchEndX = e.changedTouches[0].screenX;
                handleSwipe();
            }, {passive: true});

            function handleSwipe() {
                const swipeThreshold = 50; // minimum pixel distance to register a swipe
                if (touchEndX < touchStartX - swipeThreshold) {
                    // Swiped Left - go to next
                    nextBtn.click();
                }
                if (touchEndX > touchStartX + swipeThreshold) {
                    // Swiped Right - go to prev
                    prevBtn.click();
                }
            }
        }
    });
</script>
