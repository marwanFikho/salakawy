<Layout title="All Transformations - Salakawy | Diet & Gym Coach">
	<main class="page-container">
		<div class="container container-content fade-in-up">
			<a href="/#transformations" class="back-link">← Back to Home</a>
			
			<div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 100%; margin-bottom: 3rem; margin-top: 2rem;">
				<h1 class="section-title fade-in-up" style="margin-bottom: 0; position: relative; transform: none; display: inline-block;">All Transformations</h1>
				<span class="badge fade-in-up" style="margin-bottom: 0;">Wall of Fame</span>
				<p class="page-desc fade-in-up delay-100" style="margin-top: 0;">Witness the massive vault of real success stories and body transformations. Every journey matters!</p>
			</div>

		<!-- Age Group Filter Section -->
		<div class="age-groups-section fade-in-up delay-150">
			<h2 class="age-groups-title">Who We've Transformed</h2>
			<p class="age-groups-sub">Every age. Every body. Real results.</p>
			<div class="age-groups-row">
				{ageGroups.map((group) => {
					const hasImages = group.images.length > 0;
					const displayImages = group.images.slice(0, 4); // show up to 4 in the pile

					return (
						<button 
							class={`age-group-card ${!hasImages ? 'age-group-empty' : ''}`}
							data-group={group.slug}
							data-label={group.label}
							data-images={group.images.join(',')}
							aria-label={`Age group ${group.range}`}
						>
							<div class="pile-wrap">
								{hasImages ? (
									displayImages.reverse().map((src, idx) => (
										<img 
											class={`pile-img p${displayImages.length - idx}`} 
											src={src} 
											alt={`${group.label} transformation`} 
										/>
									))
								) : (
									<div class="pile-placeholder">
										<span>+</span>
									</div>
								)}
							</div>
							<div class="age-label">
								<span class="age-range">{group.range}</span>
							</div>
						</button>
					);
				})}
			</div>
		</div>

		<div class="masonry-grid fade-in-up delay-200" id="masonry-grid">
			{shuffledImagePaths.map((image, i) => (
				<div class="masonry-item glass-panel glass-panel-hover" style="padding: 10px; border-radius: 12px;">
					<img src={image} alt={`Transformation ${i + 1}`} loading="lazy" style="border-radius: 8px;" />
				</div>
			))}
		</div>
		</div>
	</main>

	<!-- Explosion Overlay -->
	<div id="age-explode-overlay" aria-hidden="true">
		<!-- Fullscreen Lightbox -->
		<div id="explode-lightbox">
			<img id="explode-lightbox-img" src="" alt="" />
			<span class="lightbox-close-hint">Click anywhere to close</span>
		</div>

		<div class="explode-header" id="explode-header">
			<span class="explode-title" id="explode-title"></span>
			<span class="explode-hint">Drag photos · Click to enlarge</span>
			<button class="explode-compact-btn" id="explode-compact-btn">
				<span class="compact-icon">↙</span> Compact
			</button>
		</div>

		<!-- Canvas: absolutely-positioned draggable cards land here -->
		<div id="explode-canvas"></div>
	</div>

    <!-- Gallery Modal -->
    <div id="gallery-modal" class="modal">
        <span class="close-modal" aria-label="Close">&times;</span>
        <span class="nav-btn prev-btn" aria-label="Previous">&#10094;</span>
        <img id="gallery-modal-img" class="modal-content-img" src="" alt="Full view" />
        <span class="nav-btn next-btn" aria-label="Next">&#10095;</span>
    </div>

	<WhatsappFloatingButton />
</Layout>

