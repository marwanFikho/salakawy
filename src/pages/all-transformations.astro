---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import WhatsappFloatingButton from '../components/WhatsappFloatingButton.astro';
import db from '../backend/db';

function getImagesFromDir(dirName) {
    const dirPath = path.join(process.cwd(), 'public', 'all-transformations', dirName);
    let fsImages = [];
    if (fs.existsSync(dirPath)) {
        const allFiles = fs.readdirSync(dirPath)
            .filter(file => !file.startsWith('_draft_') && /\.(jpg|jpeg|png|webp)$/i.test(file));
            
        const filtered = new Map();
        allFiles.forEach(file => {
            const baseIdentity = file.replace(/(-(\d+x\d+|scaled|1|2|3|v\d+))(\.(jpg|jpeg|png|webp))$/i, '$3');
            if (!filtered.has(baseIdentity) || (!file.includes('x') && filtered.get(baseIdentity).includes('x'))) {
                filtered.set(baseIdentity, file);
            }
        });
        fsImages = Array.from(filtered.values()).map(img => `/all-transformations/${dirName}/${img}`);
    }

    return fsImages;
}

const ageGroups = [
	{
		range: '8 – 20',
		slug: '8-20',
		label: 'Ages 8 – 20',
		images: getImagesFromDir('8-20')
	},
	{
		range: '20 – 30',
		slug: '20-30',
		label: 'Ages 20 – 30',
		images: getImagesFromDir('20-30')
	},
	{
		range: '30 – 40',
		slug: '30-40',
		label: 'Ages 30 – 40',
		images: getImagesFromDir('30-40')
	},
	{
		range: '40 – 50',
		slug: '40-50',
		label: 'Ages 40 – 50',
		images: getImagesFromDir('40-50')
	},
	{
		range: '50 – 70',
		slug: '50-70',
		label: 'Ages 50 – 70',
		images: getImagesFromDir('50-70')
	}
];

const miscImages = getImagesFromDir('MISC');
const imagePaths = [...miscImages];

// A simple deterministic shuffle so the wall looks mixed nicely
const seedRandom = (seed) => {
    let m = 0x80000000, a = 1103515245, c = 12345;
    let state = seed ? seed : Math.floor(Math.random() * (m - 1));
    return function() {
        state = (a * state + c) % m;
        return state / (m - 1);
    };
};
const rnd = seedRandom(12345);
let shuffledImagePaths = [...imagePaths];
for (let i = shuffledImagePaths.length - 1; i > 0; i--) {
    const j = Math.floor(rnd() * (i + 1));
    [shuffledImagePaths[i], shuffledImagePaths[j]] = [shuffledImagePaths[j], shuffledImagePaths[i]];
}
