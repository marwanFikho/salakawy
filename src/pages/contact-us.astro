      <div class="motivational-quotes">
        <span class="m-quote q1">Your only limit is you</span>
        <span class="m-quote q2">Decide. Commit. Succeed.</span>
        <span class="m-quote q3">Success starts with a decision</span>
        <span class="m-quote q4">Transform your life now</span>
        <span class="m-quote q5">Don't stop until you're proud</span>
      </div>
    </div>

    <div class="contact-content-wrapper">

    <!-- Hero -->
    <div class="contact-hero" id="contact-hero">
      <div class="hero-bg-blur"></div>
      <div class="container">
        <div class="contact-hero-content">
          <a href="/" class="back-link anim-item">← Back to Home</a>
          <h1 class="contact-title anim-item">Get In Touch</h1>
          <p class="contact-subtitle anim-item">Ready to <strong>take control now</strong>? Reach out directly and we will <strong>force your success</strong>.</p>
          <div class="cta-quote-wrapper anim-item">
            <p class="cta-quote">Are you ready to join them and make your life better?</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment Methods -->
    <section class="section payment-section">
      <div class="container">
        <div class="section-label anim-item">💳 Payment Methods</div>
        <h2 class="section-heading anim-item">How to Pay</h2>
        <p class="section-sub anim-item">All payments are finalized through WhatsApp. Please contact the coach first to confirm your plan and discuss your preferred payment method.</p>

        <div class="payment-cards">
          <!-- Instapay -->
          <div class="payment-card anim-item">
            <div class="payment-icon instapay-white-bg">
              <img src="/instapay-logo.png" alt="Instapay" class="method-logo" />
            </div>
            <h3 class="payment-name">Instapay</h3>
            <p class="payment-desc">Fast bank-to-bank transfers via the Instapay app</p>
            <div class="payment-badge">Instant Transfer</div>
          </div>

          <!-- Vodafone Cash -->
          <div class="payment-card anim-item">
            <div class="payment-icon no-bg">
              <img src="/vodafone-cash-logo.png" alt="Vodafone Cash" class="method-logo" />
            </div>
            <h3 class="payment-name">Vodafone Cash</h3>
            <p class="payment-desc">Send money easily using your Vodafone Cash wallet or any mobile wallet</p>
            <div class="payment-badge">Mobile Wallet</div>
          </div>

          <!-- Card Payment -->
          <div class="payment-card anim-item">
            <div class="payment-icon card-icon">
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
                <rect width="48" height="48" rx="12" fill="#1A1A2E"/>
                <rect x="8" y="14" width="32" height="20" rx="4" stroke="white" stroke-width="2.5"/>
                <line x1="8" y1="21" x2="40" y2="21" stroke="white" stroke-width="2.5"/>
                <rect x="12" y="27" width="8" height="3" rx="1.5" fill="white"/>
              </svg>
            </div>
            <h3 class="payment-name">Card Payment</h3>
            <p class="payment-desc">Pay securely with your Visa or Mastercard debit/credit card</p>
            <div class="payment-badge">Visa / Mastercard</div>
          </div>
        </div>

        <p class="payment-note anim-item">
          ⚠️ <strong>Important:</strong> All money transfers and payment confirmations are handled directly through the coach's WhatsApp. Choose a contact below to start your transformation.
        </p>
      </div>
    </section>

    <!-- Contact Cards -->
    <section class="section contacts-section">
      <div class="container">
        <div class="section-label anim-item">👋 Direct Contact</div>
        <h2 class="section-heading anim-item">Talk To Us</h2>

        <div class="contact-cards">

          <!-- Coach Card -->
          <div class="contact-card anim-item" id="coach-card">
            <div class="contact-card-inner">
              <div class="coach-photo-wrap">
                <img src={c.photo || "/coach.jpg"} alt={c.name} class="coach-photo" />
                <div class="coach-photo-ring"></div>
              </div>
              <div class="contact-info">
                <div class="contact-role" data-editable="contacts:coach.role">{c.role}</div>
                <h3 class="contact-name" data-editable="contacts:coach.name">{c.name}</h3>
                <div class="phone-row">
                  <span class="phone-number" id="coach-number" data-editable="contacts:coach.phone">{c.phone}</span>
                  <button class="copy-btn" id="copy-coach" data-number={c.phone} aria-label={`Copy ${c.name}'s number`}>
                    <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </button>
                </div>
                <div class="copy-toast hidden" id="toast-coach">✓ Number copied!</div>
                <a href={`https://wa.me/${c.whatsapp}?text=Hello%20Coach%20${c.name}`} class="btn btn-primary wa-btn" id="wa-coach-btn" target="_blank">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                  </svg>
                  Contact via WhatsApp
                </a>
              </div>
            </div>
          </div>

          <!-- Nour Card -->
          <div class="contact-card anim-item" id="nour-card">
            <div class="contact-card-inner">
              <div class="coach-photo-wrap">
                <img src={a.photo || "/Nour%20Assistant.jpeg"} alt={a.name} class="coach-photo nour-photo" />
                <div class="coach-photo-ring nour-ring"></div>
              </div>
              <div class="contact-info">
                <div class="contact-role" data-editable="contacts:assistant.role">{a.role}</div>
                <h3 class="contact-name" data-editable="contacts:assistant.name">{a.name}</h3>
                <div class="phone-row">
                  <span class="phone-number" id="nour-number" data-editable="contacts:assistant.phone">{a.phone}</span>
                  <button class="copy-btn" id="copy-nour" data-number={a.phone} aria-label={`Copy ${a.name}'s number`}>
                    <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </button>
                </div>
                <div class="copy-toast hidden" id="toast-nour">✓ Number copied!</div>
                <a href={`https://wa.me/${a.whatsapp}?text=Hello%20Coach%20${a.name}`} class="btn btn-outline wa-btn" id="wa-nour-btn" target="_blank">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                  </svg>
