---
import Layout from '../layouts/Layout.astro';
import WhatsappFloatingButton from '../components/WhatsappFloatingButton.astro';
import db from '../backend/db';

const stmt = db.prepare('SELECT content FROM site_content WHERE id = ?');
const row = stmt.get('contacts') as { content: string } | undefined;
const contacts = row ? JSON.parse(row.content) : {
  coach: { name: 'Salakawy', role: 'Head Coach', phone: '+20 121 772 0267', whatsapp: '201217720267', photo: '/coach.jpg' },
  assistant: { name: 'Nour', role: 'Assistant Coach', phone: '+20 109 215 1540', whatsapp: '201092151540', photo: '/Nour Assistant.jpeg' }
};

const c = contacts.coach || {};
const a = contacts.assistant || {};
---

<Layout title="Contact Us - Salakawy | Diet & Gym Coach">
    <!-- Background Waterfall -->
    <div class="contact-waterfall">
      <div class="waterfall-overlay"></div>
      
      <div class="masonry-container">
        <!-- Col 1 -->
        <div class="masonry-column">
          <div class="masonry-track">
            <div class="masonry-set">
              <img src="/all-transformations/20-30/IMG-20250812-WA0003-1-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20240815-WA0035-373x400.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0081-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0074-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0063-scaled.jpg" class="collage-item" alt="Transformation" />
            </div>
            <div class="masonry-set">
              <img src="/all-transformations/20-30/IMG-20250812-WA0003-1-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20240815-WA0035-373x400.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0081-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0074-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0063-scaled.jpg" class="collage-item" alt="Transformation" />
            </div>
          </div>
        </div>
        <!-- Col 2 -->
        <div class="masonry-column">
          <div class="masonry-track reverse">
            <div class="masonry-set">
              <img src="/all-transformations/20-30/mahmoud-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0066-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20250812-WA0062-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0104-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0060-scaled.jpg" class="collage-item" alt="Transformation" />
            </div>
            <div class="masonry-set">
              <img src="/all-transformations/20-30/mahmoud-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0066-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20250812-WA0062-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0104-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0060-scaled.jpg" class="collage-item" alt="Transformation" />
            </div>
          </div>
        </div>
        <!-- Col 3 -->
        <div class="masonry-column">
          <div class="masonry-track">
            <div class="masonry-set">
              <img src="/all-transformations/20-30/IMG-20250812-WA0090-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0120-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20250812-WA0126-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0084-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0129-scaled.jpg" class="collage-item" alt="Transformation" />
            </div>
            <div class="masonry-set">
              <img src="/all-transformations/20-30/IMG-20250812-WA0090-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0120-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20250812-WA0126-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0084-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0129-scaled.jpg" class="collage-item" alt="Transformation" />
            </div>
          </div>
        </div>
        <!-- Col 4 -->
        <div class="masonry-column">
          <div class="masonry-track reverse">
            <div class="masonry-set">
              <img src="/all-transformations/20-30/IMG-20250812-WA0132-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0085-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20250812-WA0082.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0105-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0127.jpg" class="collage-item" alt="Transformation" />
            </div>
            <div class="masonry-set">
              <img src="/all-transformations/20-30/IMG-20250812-WA0132-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/8-20/IMG-20250812-WA0085-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/30-40/IMG-20250812-WA0082.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/40-50/IMG-20250812-WA0105-scaled.jpg" class="collage-item" alt="Transformation" />
              <img src="/all-transformations/50-70/IMG-20250812-WA0127.jpg" class="collage-item" alt="Transformation" />
