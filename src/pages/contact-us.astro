<style>
  .contact-page {
    min-height: 100vh;
    background: #0d0e12;
    overflow-x: hidden;
    position: relative;
    width: 100%;
    color: #fff;
  }

  .contact-content-wrapper {
    position: relative;
    z-index: 10;
  }

  /* ── Waterfall Background ── */
  .contact-waterfall {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.55; /* Increased opacity for better visibility */
    overflow: hidden;
    pointer-events: none;
    background: #0d0e12;
  }

  .waterfall-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 10%, rgba(13, 14, 18, 0.85) 90%),
                linear-gradient(to bottom, rgba(13, 14, 18, 0.95) 0%, transparent 20%, transparent 80%, rgba(13, 14, 18, 0.95) 100%);
    z-index: 5;
  }

  .masonry-container {
    display: flex;
    gap: 15px;
    padding: 0;
    width: 100%;
    height: 120%; /* Extra height to prevent gaps */
    transform: rotate(-1deg) scale(1.05);
  }

  .masonry-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .masonry-track {
    display: flex;
    flex-direction: column;
    gap: 15px;
    animation: waterfall-scroll 45s linear infinite;
    will-change: transform; /* Hardware acceleration */
  }

  .masonry-track.reverse {
    animation: waterfall-scroll-rev 45s linear infinite;
  }

  .masonry-set {
    display: flex;
    flex-direction: column;
    gap: 15px;
    flex-shrink: 0;
  }

  .collage-item {
    width: 100%;
    height: auto;
    border-radius: 4px;
    filter: brightness(0.85) contrast(1.1); /* Clearer images */
    opacity: 0.9;
    display: block;
  }

  @keyframes waterfall-scroll {
    0% { transform: translateY(-50.5%); }
    100% { transform: translateY(0%); }
  }

  @keyframes waterfall-scroll-rev {
    0% { transform: translateY(0%); }
    100% { transform: translateY(-50.5%); }
  }

  /* ── CTA Quote ── */
  .cta-quote-wrapper {
    margin-top: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(255, 255, 0, 0.2);
    border-bottom: 1px solid rgba(255, 255, 0, 0.2);
    width: fit-content;
  }

  .cta-quote {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--accent-color);
    font-style: italic;
    text-shadow: 0 0 20px rgba(255, 255, 0, 0.3);
  }

  /* ── Motivational Quotes ── */
  .motivational-quotes {
    position: absolute;
    inset: 0;
    z-index: 6;
  }

  .m-quote {
    position: absolute;
    color: rgba(255, 255, 255, 0.15);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 4px;
    font-size: clamp(1rem, 3vw, 2.5rem);
    white-space: nowrap;
    pointer-events: none;
    animation: quote-float 10s ease-in-out infinite alternate;
  }

  .q1 { top: 15%; left: 5%; animation-delay: 0s; }
  .q2 { top: 40%; right: 10%; animation-delay: 2s; }
  .q3 { top: 65%; left: 15%; animation-delay: 4s; }
  .q4 { top: 85%; right: 5%; animation-delay: 1s; }
  .q5 { top: 25%; right: 20%; animation-delay: 3s; font-size: 1.5rem; }

  @keyframes quote-float {
    from { transform: translateY(0) translateX(0); opacity: 0.1; }
    to { transform: translateY(-20px) translateX(10px); opacity: 0.3; }
  }

  /* ── Hero ── */
  .contact-hero {
    position: relative;
    padding: 120px 0 60px;
    overflow: hidden;
  }

  .hero-bg-blur {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(255,255,0,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-hero-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    width: fit-content;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent-color); }

  .contact-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #fff 30%, rgba(255,255,0,0.85) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .contact-subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 500px;
  }

  /* ── Shared Section Styles ── */
  .section-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent-color);
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .section-sub {
    color: var(--text-muted);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    font-size: 1rem;
  }

  @media (max-width: 600px) {
    .section-label, .section-heading, .section-sub {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* ── Payment Section ── */
  .payment-section {
    background: var(--surface-color);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    width: 100%;
    position: relative;
  }

  .payment-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .payment-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.3s, transform 0.3s;
  }

  .payment-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-8px);
    box-shadow: 0 10px 40px -10px rgba(255, 255, 0, 0.15);
    background: rgba(255, 255, 255, 0.05);
  }

  .payment-icon {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }

  .payment-icon.no-bg {
    background: transparent;
  }

  .payment-icon.instapay-white-bg {
    background: #ffffff;
  }

  .method-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .payment-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .payment-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .payment-badge {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(255,255,0,0.1);
    border: 1px solid rgba(255,255,0,0.2);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-color);
    width: fit-content;
  }

  .payment-note {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  /* ── Contacts Section ── */
  .contacts-section {
    background: var(--bg-color);
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .contact-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 2.5rem;
    transition: border-color 0.3s, transform 0.3s;
    position: relative;
    overflow: hidden;
  }

  .contact-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .contact-card:hover {
    border-color: rgba(255,255,0,0.2);
    transform: translateY(-4px);
  }

  .contact-card:hover::before { opacity: 1; }

  .contact-card-inner {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  /* Coach Photo */
  .coach-photo-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .coach-photo {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 50%;
    display: block;
    border: 3px solid rgba(255,255,0,0.3);
  }

  .nour-photo {
    /* To center her face, change this percentage. 
       First number is Left/Right (50% is middle).
       Second number is Top/Bottom (0% is top, 100% is bottom). */
    object-position: 50% 20%; 
  }

  .coach-photo-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid transparent;
    border-top-color: var(--accent-color);
    border-right-color: var(--accent-color);
    animation: ring-spin 3s linear infinite;
  }

  .nour-ring {
    border-top-color: rgba(255,255,255,0.4);
    border-right-color: rgba(255,255,255,0.4);
  }

  @keyframes ring-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Initials Avatar */
  .initials-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, #111, #222);
    border: 2px dashed rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--accent-color);
    text-shadow: 0 0 20px rgba(255, 255, 0, 0.3);
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .contact-role {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent-color);
  }

  .contact-name {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-main);
    line-height: 1;
  }

  /* Phone Row */
  .phone-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0.4rem 0;
  }

  .phone-number {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-main);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.5px;
  }

  .copy-btn {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 7px 9px;
    cursor: pointer;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: rgba(255,255,0,0.1);
    border-color: rgba(255,255,0,0.3);
    color: var(--accent-color);
  }

  .copy-btn.copied {
    background: rgba(34,197,94,0.15);
    border-color: rgba(34,197,94,0.4);
  }

  .check-icon { display: none; }
  .check-icon.showing { display: block; }
  .copy-icon.hiding { display: none; }

  .copy-toast {
    font-size: 0.82rem;
    color: #22c55e;
    font-weight: 600;
    height: 0;
    overflow: hidden;
    transition: height 0.2s;
  }

  .copy-toast.visible {
    height: 1.2em;
  }

  /* WhatsApp Button */
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 0.95rem;
    width: fit-content;
    margin-top: 0.4rem;
  }

  .btn-outline {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--text-main);
    transition: border-color 0.25s, background 0.25s;
  }
  .btn-outline:hover {
    border-color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.05);
    color: var(--text-main);
  }

  /* Hidden utility */
  .hidden { display: none !important; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-cards { grid-template-columns: 1fr; }
    .payment-cards { grid-template-columns: 1fr; }
    .contact-card-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  }

  @media (max-width: 600px) {
    .contact-hero { padding: 100px 0 40px; }
    .payment-cards { gap: 1rem; width: 100%; }
    .contact-card { padding: 2.5rem 1.5rem; }
    .payment-note { text-align: center; }
    .contact-card-inner { align-items: center; text-align: center; }
    .phone-row { justify-content: center; }
    .wa-btn { align-self: center; }
    .contact-info { align-items: center; }
  }
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

document.addEventListener('astro:page-load', () => {
  if (!document.querySelector('.contact-page')) return;

  gsap.registerPlugin(ScrollTrigger);

  // ── Staggered hero entrance
  gsap.fromTo('.contact-hero .anim-item',
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, stagger: 0.15, duration: 0.8, ease: 'power3.out', delay: 0.1 }
  );

  // ── Section elements animate in on scroll
  gsap.utils.toArray('.payment-card').forEach((card, i) => {
    gsap.fromTo(card,
      { opacity: 0, y: 50, scale: 0.95 },
      {
        opacity: 1, y: 0, scale: 1,
        duration: 0.7, ease: 'back.out(1.4)',
        delay: i * 0.1,
        scrollTrigger: { trigger: card, start: 'top 85%', once: true }
      }
    );
  });

  gsap.utils.toArray('.contact-card').forEach((card, i) => {
    gsap.fromTo(card,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0,
        duration: 0.8, ease: 'power3.out',
        delay: i * 0.15,
        scrollTrigger: { trigger: card, start: 'top 85%', once: true }
      }
    );
  });

  const scrollLabels = document.querySelectorAll('.section-label, .section-heading, .section-sub, .payment-note');
  scrollLabels.forEach(el => {
    gsap.fromTo(el,
      { opacity: 0, y: 25 },
      {
        opacity: 1, y: 0, duration: 0.65, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%', once: true }
      }
    );
  });

  // ── Copy buttons
  function setupCopyBtn(btnId, toastId) {
    const btn = document.getElementById(btnId);
    const toast = document.getElementById(toastId);
    if (!btn || !toast) return;

    btn.addEventListener('click', async () => {
      const number = btn.dataset.number;
      try {
        await navigator.clipboard.writeText(number);
      } catch {
        // Fallback for older browsers
        const ta = document.createElement('textarea');
        ta.value = number;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }

      // Swap icons
      btn.querySelector('.copy-icon').classList.add('hiding');
      btn.querySelector('.check-icon').classList.add('showing');
      btn.classList.add('copied');
      toast.classList.remove('hidden');

      // Animate toast in
      gsap.fromTo(toast, { opacity: 0, y: -6 }, { opacity: 1, y: 0, duration: 0.3 });
      toast.classList.add('visible');

      setTimeout(() => {
        gsap.to(toast, {
          opacity: 0, y: -6, duration: 0.3,
          onComplete: () => {
            toast.classList.remove('visible');
            toast.classList.add('hidden');
            btn.querySelector('.copy-icon').classList.remove('hiding');
            btn.querySelector('.check-icon').classList.remove('showing');
            btn.classList.remove('copied');
          }
        });
      }, 2500);
    });
  }

  setupCopyBtn('copy-coach', 'toast-coach');
  setupCopyBtn('copy-nour',  'toast-nour');

  // ── WhatsApp buttons — open wa.me in new tab
  document.getElementById('wa-coach-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.open('https://wa.me/201217720267', '_blank', 'noopener');
  });

  document.getElementById('wa-nour-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.open(`https://wa.me/${document.getElementById('copy-nour').dataset.number.replace(/\s+/g, '').replace('+', '')}`, '_blank', 'noopener');
  });

  // ── Scroll to contacts on payment card click
  document.querySelectorAll('.payment-card').forEach(card => {
    card.style.cursor = 'pointer';
    card.addEventListener('click', () => {
      const contactsSection = document.getElementById('contacts-section');
      if (contactsSection) {
        contactsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
});
</script>
