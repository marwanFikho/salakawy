---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '../../lib/admin-auth';

const auth = checkAdminAuth(Astro);
if (!auth.authenticated) return auth.redirect;
---

<AdminLayout title="Media Library" activePanel="photos">
    <div class="media-page">
        <div class="media-controls glass-card">
            <div class="category-tabs" style="flex-wrap: wrap;">
                <button class="cat-tab active" data-cat="hero">Hero Images</button>
                <button class="cat-tab" data-cat="8-20">Ages 8-20</button>
                <button class="cat-tab" data-cat="20-30">Ages 20-30</button>
                <button class="cat-tab" data-cat="30-40">Ages 30-40</button>
                <button class="cat-tab" data-cat="40-50">Ages 40-50</button>
                <button class="cat-tab" data-cat="50-70">Ages 50-70</button>
                <button class="cat-tab" data-cat="MISC">Overall Gallery (MISC)</button>
                <button class="cat-tab" data-cat="coach">Coach Photos</button>
            </div>
            
            <div class="upload-trigger" id="upload-zone">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>Upload New Media</span>
                <input type="file" id="file-input" accept="image/*" multiple style="display:none" />
            </div>
        </div>

        <div class="media-grid" id="photos-grid">
            <!-- Loaded via JS -->
        </div>

        <!-- Custom Delete Modal -->
        <div id="delete-modal" class="custom-modal">
            <div class="custom-modal-content">
                <h3>Delete Photo</h3>
                <p>Are you sure you want to permanently delete this photo? This cannot be undone.</p>
                <div class="modal-actions">
                    <button class="modal-btn cancel" onclick="closeDeleteModal()">Cancel</button>
                    <button class="modal-btn danger" onclick="confirmDelete()">Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>

    <style is:global>
        .media-page { display: flex; flex-direction: column; gap: 2.5rem; }

        .media-controls { 
            padding: 1.25rem 2rem; 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            position: sticky;
            top: 6rem;
            z-index: 100;
        }

        .category-tabs { display: flex; gap: 0.75rem; }
        .cat-tab {
            background: transparent;
            border: 1px solid transparent;
            padding: 0.6rem 1.25rem;
            border-radius: 12px;
            color: rgba(255, 255, 255, 0.4);
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        .cat-tab:hover { color: #fff; background: rgba(255,255,255,0.05); }
        .cat-tab.active { background: rgba(226, 255, 0, 0.1); border-color: rgba(226, 255, 0, 0.2); color: #E2FF00; }

        .upload-trigger {
            background: var(--brand-lime);
            color: #000;
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            font-weight: 800;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 20px rgba(226, 255, 0, 0.2);
        }
        .upload-trigger:hover { transform: scale(1.05); box-shadow: 0 15px 30px rgba(226, 255, 0, 0.3); }

        .media-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
        }

        .photo-card {
            background: #111;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: all 0.3s;
        }
        
        .photo-card:hover {
            border-color: rgba(226, 255, 0, 0.4);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .photo-img-wrap {
            position: relative;
            width: 100%;
            height: 260px;
            background: #050505;
        }

        .photo-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .photo-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            padding: 0.4rem 0.8rem;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        .badge-draft { background: #fbbf24; color: #000; }
        .badge-published { background: #4ade80; color: #000; }

        .photo-actions {
            padding: 1rem;
            display: flex;
            gap: 0.5rem;
            justify-content: space-between;
        }

        .action-btn {
            flex: 1;
            padding: 0.6rem;
            border-radius: 8px;
            border: none;
            font-weight: 700;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        .pub-btn { background: var(--brand-lime); color: #000; }
        .pub-btn:hover { background: #cce600; }
        .unpub-btn { background: rgba(255, 255, 255, 0.1); color: #fff; }
        .unpub-btn:hover { background: rgba(255, 255, 255, 0.2); }
        .del-btn { background: rgba(239, 68, 68, 0.1); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2); }
        .del-btn:hover { background: rgba(239, 68, 68, 0.2); }

        .custom-modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(5px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: all 0.2s;
        }
        .custom-modal.active {
            opacity: 1;
            pointer-events: auto;
        }
        .custom-modal-content {
            background: #111;
            border: 1px solid rgba(255,255,255,0.1);
            padding: 2rem;
            border-radius: 16px;
            max-width: 400px;
            width: 90%;
            text-align: center;
            transform: scale(0.9);
            transition: all 0.2s;
        }
        .custom-modal.active .custom-modal-content {
            transform: scale(1);
        }
        .custom-modal-content h3 { margin-top: 0; color: #fff; }
        .custom-modal-content p { color: rgba(255,255,255,0.6); font-size: 0.9rem; margin-bottom: 2rem; }
        .modal-actions { display: flex; gap: 1rem; }
        .modal-btn { flex: 1; padding: 0.8rem; border-radius: 8px; border: none; font-weight: bold; cursor: pointer; }
        .modal-btn.cancel { background: rgba(255,255,255,0.1); color: #fff; }
        .modal-btn.danger { background: #ef4444; color: #fff; }
    </style>

    <script is:inline>
        let currentCat = 'hero';

        async function fetchPhotos() {
            try {
                const res = await fetch(`/api/admin/upload?category=${currentCat}`);
                const photos = await res.json();
                renderPhotos(photos);
            } catch (err) {
                console.error('Failed to fetch photos:', err);
            }
        }

        function renderPhotos(photos) {
            const grid = document.getElementById('photos-grid');
            if (!photos.length) {
                grid.innerHTML = '<div style="grid-column: 1/-1; padding: 10rem; text-align: center; color: rgba(255,255,255,0.2);">No media found in this category.</div>';
                return;
            }

            grid.innerHTML = photos.map(p => `
                <div class="photo-card">
                    <div class="photo-img-wrap">
                        <img src="${p.public_url}" alt="" loading="lazy" />
                        <div class="photo-badge badge-${p.status}">${p.status}</div>
                    </div>
                    <div class="photo-actions">
                        ${p.status === 'draft' 
                            ? `<button class="action-btn pub-btn" onclick="updateStatus('${p.id}', 'published')">Publish</button>`
                            : `<button class="action-btn unpub-btn" onclick="updateStatus('${p.id}', 'draft')">Draft</button>`
                        }
                        <button class="action-btn del-btn" onclick="deletePhoto('${p.id}', '${p.storage_path}')">Delete</button>
                    </div>
                </div>
            `).join('');
        }

        async function updateStatus(id, status) {
            const res = await fetch('/api/admin/upload', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, status, category: currentCat })
            });
            if (res.ok) {
                showToast(status === 'published' ? 'Image is now LIVE!' : 'Image moved to DRAFTS');
                fetchPhotos();
            }
        }

        let photoToDelete = null;

        async function deletePhoto(id, storage_path) {
            photoToDelete = { id, storage_path, category: currentCat };
            document.getElementById('delete-modal').classList.add('active');
        }

        async function confirmDelete() {
            if (!photoToDelete) return;
            const { id, storage_path, category } = photoToDelete;
            
            const res = await fetch('/api/admin/upload', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, storage_path, category })
            });
            
            closeDeleteModal();
            
            if (res.ok) {
                showToast('Image deleted.', 'success');
                fetchPhotos();
            }
        }

        function closeDeleteModal() {
            photoToDelete = null;
            document.getElementById('delete-modal').classList.remove('active');
        }

        // Convert any image to real JPEG via canvas (handles HEIF, HEVC, etc.)
        function convertToJpeg(file) {
            return new Promise((resolve, reject) => {
                const img = new Image();
                const url = URL.createObjectURL(file);
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    canvas.width = img.naturalWidth;
                    canvas.height = img.naturalHeight;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0);
                    URL.revokeObjectURL(url);
                    canvas.toBlob((blob) => {
                        if (blob) {
                            const name = file.name.replace(/\.[^.]+$/, '.jpg');
                            resolve(new File([blob], name, { type: 'image/jpeg' }));
                        } else {
                            reject(new Error('Canvas conversion failed'));
                        }
                    }, 'image/jpeg', 0.85);
                };
                img.onerror = () => {
                    URL.revokeObjectURL(url);
                    reject(new Error('Image load failed'));
                };
                img.src = url;
            });
        }

        // Upload zone
        const zone = document.getElementById('upload-zone');
        const input = document.getElementById('file-input');
        zone.addEventListener('click', () => input.click());
        input.addEventListener('change', async () => {
            const files = Array.from(input.files);
            for (const originalFile of files) {
                showToast(`Processing ${originalFile.name}...`);
                let file;
                try {
                    file = await convertToJpeg(originalFile);
                } catch (e) {
                    // Fallback: upload as-is if conversion fails
                    file = originalFile;
                }
                const fd = new FormData();
                fd.append('file', file);
                fd.append('category', currentCat);
                showToast(`Uploading ${file.name}...`);
                const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
                if (res.ok) showToast('Upload complete!');
                else showToast('Upload failed!');
            }
            input.value = '';
            fetchPhotos();
        });

        // Tabs
        document.querySelectorAll('.cat-tab').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentCat = btn.dataset.cat;
                fetchPhotos();
            });
        });

        fetchPhotos();
    </script>
</AdminLayout>
