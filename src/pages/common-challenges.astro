---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import { getContent, getVal } from '../backend/content';

const defaultTopics = [
	{ title: "Low Motivation", folderKeywords: [], customImage: "/transformations/1.jpg", hint: "I know how hard it feels because I've been exactly where you are. I used to be miserable about how I looked and felt, but I started working out until I absolutely fell in love with it. That journey completely changed my reality, and now it's my mission to change yours. I will be checking in with you every single day—acting as your push forward until your own discipline kicks in!" },
	{ title: "Emotional Eating", folderKeywords: ["Emotional Eating", "Emotional Eating 2"], hint: "Salakawy targets emotional eating by providing flexible, enjoyable meal plans that reduce restrictive mindsets, alongside daily responses to keep you accountable without guilt." },
	{ title: "Sugar Cravings", folderKeywords: ["Sugar Craving"], hint: "Even these children did control their sugar craving, imagine what you can do. By balancing your macronutrients and ensuring you eat satisfying food, Salakawy naturally curbs intense sugar cravings without asking you to give up everything you love." },
	{ title: "Belly Fat", folderKeywords: ["Belly Fat"], hint: "Nothing is called spot fat reduction, that's a myth. Stubborn belly fat requires a consistent caloric deficit and targeted lifestyle changes. Salakawy's precise nutrition planning ensures fat is burned efficiently over time." },
	{ title: "Arm Fat", folderKeywords: ["Arm Fats"], hint: "Targeting overall body fat through progressive training and diet is the key. Coach Salakawy incorporates strength exercises that tone and redefine your arms." },
	{ title: "Legs Fat", folderKeywords: ["Legs Fats"], hint: "Toning your legs comes down to a proper caloric deficit combined with targeted lower body resistance training, which Salakawy seamlessly incorporates into your plan." },
	{ title: "Slow Metabolism", folderKeywords: [], hint: "A 'slow' metabolism is often just low activity and poor diet history. We reset it by feeding your body enough food and gradually increasing your muscle mass." },
	{ title: "Weight Plateau", folderKeywords: ["Whey Plateau"], hint: "Plateaus are normal. Coach Salakawy tweaks your macros, adjusts your workouts, or introduces diet breaks to ignite fat loss once more." },
	{ title: "Stress", folderKeywords: ["Stress"], hint: "Stress increases cortisol, holding onto fat. We focus on sustainable habits, avoiding crash diets that add more stress to your nervous system." },
	{ title: "Poor Sleep", folderKeywords: ["Sleeping"], hint: "Diet heavily affects sleep quality. Salakawy adjusts your meal timing to ensure your body recovers beautifully overnight." },
	{ title: "Night Eating", folderKeywords: ["Night Eating"], hint: "Eating at night isn't inherently bad, but overeating is. We schedule your calories so you're satisfied before bed and never wake up hungry." },
	{ title: "Hormonal Imbalance", folderKeywords: [], hint: "Conditions like PCOS or Insulin Resistance need care. The coaching platform tailors food specifically to balance your blood sugar and hormones." },
	{ title: "Water Retention", folderKeywords: ["Water Retention"], hint: "Hydration and sodium balancing are built into your plan. Salakawy ensures you drop that excess water weight fast and safely." },
	{ title: "Bloating", folderKeywords: [], hint: "A healthy gut is essential. We eliminate foods that trigger you and focus on digesting smoothly so your stomach stays perfectly flat." },
	{ title: "Hidden Eating", folderKeywords: [], hint: "It’s hard to talk about, but Coach Salakawy gets it. Unlocking the emotional reason behind hidden eating happens when you feel no judgment." },
	{ title: "High Calories", folderKeywords: [], hint: "We teach you volume eating: eating huge, delicious meals that are surprisingly low in calories to keep you full all day." },
	{ title: "Inconsistency", folderKeywords: ["Inconsistency"], hint: "By removing extreme restrictions, Salakawy makes the diet so easy and enjoyable that being consistent becomes second nature." },
	{ title: "Injuries", folderKeywords: ["Injuries"], hint: "Got an injury? No problem. The diet adjusts to your lower activity levels, and workouts are modified to focus on what you CAN do, not what you can't." },
	{ title: "Laziness", folderKeywords: [], hint: "It's not laziness; you're just lacking the right fuel! We adjust your carbs and nutrients to give you soaring energy levels." },
	{ title: "Comparisons", folderKeywords: [], hint: "Social media can be tough. Salakawy roots you in your own progress through data tracking, showing how far YOU have come." },
	{ title: "Aging", folderKeywords: ["50_plus_old_age"], hint: "Age is just a number. Coach Salakawy adapts the intensity and volume specifically to support your joints, hormones, and metabolism as you age." }
];

const c = getContent('challenges_page');
const baseTopics = getVal(c, 'items', defaultTopics);

const publicDir = path.join(process.cwd(), 'public');

const struggles = baseTopics.map(topic => {
	let images = [];
	
	topic.folderKeywords.forEach(keyword => {
		// Single file match
		const possibleFilePath = path.join(publicDir, `${keyword}.jpeg`);
		if (fs.existsSync(possibleFilePath) && fs.statSync(possibleFilePath).isFile()) {
			images.push(`/${keyword}.jpeg`);
		}
		
		// Directory match
		const possibleDirPath = path.join(publicDir, keyword);
		if (fs.existsSync(possibleDirPath) && fs.statSync(possibleDirPath).isDirectory()) {
			const files = fs.readdirSync(possibleDirPath)
				.filter(f => /\.(jpg|jpeg|png|webp)$/i.test(f))
				.map(f => `/${keyword}/${f}`);
			images = images.concat(files);
		}
	});

	if (topic.customImage) {
		images = [topic.customImage];
	}

	return {
		title: topic.title,
		id: topic.title.toLowerCase().replace(/\s+/g, '-'),
		hint: topic.hint,
		images: images
	};
});
---

<Layout title="Your Struggles & Fat Types - Salakawy">
	<main>
		<section class="section struggles-hero" style="padding-top: 150px; text-align: center;">
			<div class="container">
				<h1 class="fade-in-up" style="font-size: 3rem; margin-bottom: 1rem; color: var(--text-main);" data-editable="challenges_page:header.title" set:html={getVal(c, 'header.title', 'Identify Your <span style="color: var(--accent-color);">Obstacles</span>')} />
				<p class="fade-in-up delay-100" style="max-width: 700px; margin: 0 auto 2rem auto; color: var(--text-muted); font-size: 1.2rem;" data-editable="challenges_page:header.desc" set:html={getVal(c, 'header.desc', 'Everyone fights a different battle. Explore the struggles below and discover how Coach Salakawy can <strong>force your success</strong>. It is time to <strong>stop making excuses</strong> and <strong>start acting today</strong>.')} />
			</div>
		</section>

		<!-- Struggles Grid -->
		<section class="section struggles-grid-section bg-surface">
			<div class="container">
				<div class="struggles-wrapper">
					{struggles.map((item, index) => {
						const hasImages = item.images && item.images.length > 0;
						const isSingleImage = item.images && item.images.length === 1;
						const displayImages = hasImages ? item.images.slice(0, 4) : [];

						return (
							<div id={item.id} class="struggle-detail-card glass-panel fade-in-up" style={`animation-delay: ${index * 50}ms`}>
								{hasImages && !isSingleImage && (
									<button 
										class="struggle-group-card"
										data-id={item.id}
										data-label={item.title}
										data-images={item.images.join(',')}
										aria-label={`Open photos for ${item.title}`}
										style="border: none; background: transparent; padding: 0; outline: none; margin: 1.5rem auto 0 auto; display: block;"
									>
										<div class="pile-wrap">
											{displayImages.reverse().map((src, idx) => (
												<img 
													class={`pile-img p${displayImages.length - idx}`} 
													src={src} 
													alt={`${item.title} example`} 
												/>
											))}
											<div class="expand-hint">Click photos to view all</div>
										</div>
									</button>
								)}
								{hasImages && isSingleImage && (
									<div class={`card-image single-img-wrap ${item.id === 'low-motivation' ? 'full-size-wrap' : ''}`}>
										<img src={item.images[0]} alt={`${item.title} example`} loading="lazy" />
									</div>
								)}
								<div class="card-content">
									<h3 class="card-title" data-editable={`challenges_page:items.${index}.title`} set:html={item.title} />
									<p class="card-hint" data-editable={`challenges_page:items.${index}.hint`} set:html={item.hint} />
								</div>
							</div>
						);
					})}
				</div>

				<div style="text-align: center; margin-top: 4rem;" class="fade-in-up delay-300">
					<h3 style="margin-bottom: 1.5rem;" data-editable="challenges_page:footer.title" set:html={getVal(c, 'footer.title', 'Ready to stop making excuses and <strong>claim your transformation now</strong>?')} />
					<a href="/contact-us" class="btn btn-primary" data-editable="challenges_page:footer.btn" set:html={getVal(c, 'footer.btn', 'Force Your Success')} />
				</div>
			</div>
		</section>
	</main>

	<!-- Explosion Overlay -->
	<div id="struggle-explode-overlay" aria-hidden="true">
		<!-- Fullscreen Lightbox -->
		<div id="explode-lightbox">
			<img id="explode-lightbox-img" src="" alt="" />
			<span class="lightbox-close-hint">Click anywhere to close</span>
		</div>

		<div class="explode-header" id="explode-header">
			<span class="explode-title" id="explode-title"></span>
			<span class="explode-hint">Drag photos · Click to enlarge</span>
			<button class="explode-compact-btn" id="explode-compact-btn">
				<span class="compact-icon">↙</span> Compact
			</button>
		</div>

		<!-- Canvas: absolutely-positioned draggable cards land here -->
		<div id="explode-canvas"></div>
	</div>
</Layout>

<style>
	.bg-surface {
		background-color: var(--surface-color);
	}

	.struggles-wrapper {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
	}

	.struggle-detail-card {
		scroll-margin-top: 25vh;
		display: flex;
		flex-direction: column;
		border-radius: var(--radius);
		overflow: hidden;
		transition: transform var(--transition);
		background: var(--bg-color);
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.struggle-detail-card:hover {
		transform: translateY(-5px);
		border-color: rgba(255, 255, 0, 0.2);
	}

	.single-img-wrap {
		width: 100%;
		height: 200px;
		overflow: hidden;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.single-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--transition);
	}

	.struggle-detail-card:hover .single-img-wrap img {
		transform: scale(1.05);
	}

	.full-size-wrap {
		height: auto;
		padding: 1rem;
	}

	.full-size-wrap img {
		height: auto;
		border-radius: 8px;
		object-fit: contain;
	}

	.card-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		flex-grow: 1;
		align-items: center;
		text-align: center;
	}

	.card-title {
		margin: 0;
		color: var(--accent-color);
		font-size: 1.5rem;
	}

	.card-hint {
		margin: 0;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.6;
	}

	/* ── Pile of photos (adapted from all-transformations.astro) ── */
	.struggle-group-card {
		cursor: pointer;
		position: relative;
	}

	.pile-wrap {
		position: relative;
		width: 140px;
		height: 160px;
		margin: 0 auto;
	}

	.pile-img {
		position: absolute;
		width: 120px;
		height: 150px;
		object-fit: cover;
		border-radius: 12px;
		border: 3px solid rgba(255,255,255,0.15);
		box-shadow: 0 4px 15px rgba(0,0,0,0.5);
		transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s ease;
		top: 5px;
		left: 50%;
	}

	.pile-img.p1 { transform: translateX(-50%) rotate(-6deg); z-index: 1; }
	.pile-img.p2 { transform: translateX(-50%) rotate(3deg);  z-index: 2; }
	.pile-img.p3 { transform: translateX(-50%) rotate(9deg);  z-index: 3; }
	.pile-img.p4 { transform: translateX(-50%) rotate(-2deg); z-index: 4; top: 0; }

	.expand-hint {
		position: absolute;
		bottom: -15px;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.75rem;
		color: var(--accent-color);
		opacity: 0;
		transition: opacity 0.3s ease;
		white-space: nowrap;
		font-weight: 600;
	}

	/* Fan out on hover */
	.struggle-group-card:hover .pile-img.p1 { transform: translateX(-50%) rotate(-16deg) translateY(5px); box-shadow: 0 6px 20px rgba(0,0,0,0.6); }
	.struggle-group-card:hover .pile-img.p2 { transform: translateX(-50%) rotate(0deg)   translateY(-3px); }
	.struggle-group-card:hover .pile-img.p3 { transform: translateX(-50%) rotate(16deg)  translateY(5px); box-shadow: 0 6px 20px rgba(0,0,0,0.6); }
	.struggle-group-card:hover .pile-img.p4 { transform: translateX(-50%) rotate(6deg)   translateY(-8px); box-shadow: 0 8px 25px rgba(255,255,0,0.15); }
	.struggle-group-card:hover .expand-hint { opacity: 1; }

	/* ── Explosion Overlay ──────────────────────────────── */
	#struggle-explode-overlay {
		position: fixed;
		inset: 0;
		z-index: 8500;
		background: rgba(5, 5, 8, 0.96);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	#struggle-explode-overlay.open {
		opacity: 1;
		pointer-events: all;
	}

	.explode-header {
		position: sticky;
		top: 0;
		z-index: 10000;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 2rem;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(255, 255, 0, 0.12);
		flex-shrink: 0;
	}

	.explode-title {
		font-size: 1.3rem;
		font-weight: 800;
		color: var(--accent-color);
		letter-spacing: -0.01em;
	}

	.explode-hint {
		font-size: 0.9rem;
		color: rgba(255,255,255,0.45);
		letter-spacing: 0.04em;
		flex: 1;
		text-align: center;
	}

	.explode-compact-btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255, 255, 0, 0.1);
		border: 1px solid rgba(255, 255, 0, 0.3);
		color: var(--accent-color);
		font-size: 0.95rem;
		font-weight: 700;
		padding: 0.5rem 1.2rem;
		border-radius: 30px;
		cursor: pointer;
		transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
	}

	.explode-compact-btn:hover {
		background: rgba(255, 255, 0, 0.2);
		transform: scale(1.04);
		box-shadow: 0 4px 15px rgba(255, 255, 0, 0.2);
	}

	.compact-icon {
		font-size: 1.1rem;
		display: inline-block;
		transition: transform 0.3s ease;
	}

	.explode-compact-btn:hover .compact-icon {
		transform: translate(-2px, 2px);
	}

	#explode-canvas {
		position: fixed;
		top: 62px;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 8501;
		overflow: hidden;
		pointer-events: none;
	}

	#struggle-explode-overlay.open #explode-canvas {
		pointer-events: all;
	}

	#explode-lightbox {
		position: fixed;
		inset: 0;
		z-index: 9500;
		background: rgba(0, 0, 0, 0.92);
		backdrop-filter: blur(6px);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease;
	}

	#explode-lightbox.open {
		opacity: 1;
		pointer-events: all;
	}

	#explode-lightbox img {
		max-width: 90vw;
		max-height: 88vh;
		object-fit: contain;
		border-radius: 10px;
		box-shadow: 0 20px 60px rgba(0,0,0,0.8);
		transition: transform 0.35s cubic-bezier(0.34, 1.3, 0.64, 1), opacity 0.3s ease;
		transform: scale(0.85);
		opacity: 0;
		pointer-events: none;
	}

	#explode-lightbox.open img {
		transform: scale(1);
		opacity: 1;
	}

	.lightbox-close-hint {
		position: absolute;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		color: rgba(255,255,255,0.45);
		font-size: 0.85rem;
		letter-spacing: 0.04em;
		pointer-events: none;
	}
</style>

<script>
    document.addEventListener('astro:page-load', () => {

		// ── Image Group Explosion — powered by GSAP ──────────────────
		import('gsap').then(({ gsap }) => {

		const overlay      = document.getElementById('struggle-explode-overlay');
		const explodeCanvas= document.getElementById('explode-canvas');
		const explodeTitle = document.getElementById('explode-title');
		const compactBtn   = document.getElementById('explode-compact-btn');
		const groupCards   = document.querySelectorAll('.struggle-group-card');

		if (!overlay || groupCards.length === 0) return;

		const HEADER_H = 62;
		let sourceCard = null;
		let sourceRect = null;
		let activeCards = [];

		// Inject hover/drag styles (bypass Astro CSS scoping on JS-created elements)
		if (!document.getElementById('explode-dynamic-styles')) {
			const st = document.createElement('style');
			st.id = 'explode-dynamic-styles';
			st.textContent = [
				'.explode-item-card:hover { border-color: rgba(255,255,0,.5) !important; box-shadow: 0 8px 28px rgba(255,255,0,.25) !important; }',
				'.explode-item-card.is-dragging { cursor: grabbing !important; box-shadow: 0 20px 50px rgba(0,0,0,.9) !important; z-index: 200 !important; }'
			].join('');
			document.head.appendChild(st);
		}

		// ── Drag (synced with GSAP's transform state) ──────────────
		function makeDraggable(el) {
			let dragging = false, startX, startY, startGX, startGY, moved = false;

			function start(cx, cy) {
				dragging = true; moved = false;
				startX = cx; startY = cy;
				startGX = gsap.getProperty(el, 'x');
				startGY = gsap.getProperty(el, 'y');
				el.classList.add('is-dragging');
				gsap.set(el, { zIndex: 100 });
			}
			function move(cx, cy) {
				if (!dragging) return;
				const dx = cx - startX, dy = cy - startY;
				if (Math.abs(dx) > 3 || Math.abs(dy) > 3) moved = true;
				gsap.set(el, { x: startGX + dx, y: startGY + dy });
			}
			function finish() {
				if (!dragging) return;
				dragging = false;
				el._wasMoved = moved;
				el.classList.remove('is-dragging');
				gsap.set(el, { zIndex: '' });
			}

			el.addEventListener('mousedown',  e => { e.preventDefault(); start(e.clientX, e.clientY); });
			window.addEventListener('mousemove', e => move(e.clientX, e.clientY));
			window.addEventListener('mouseup', finish);
			el.addEventListener('touchstart', e => start(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
			el.addEventListener('touchmove',  e => move(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
			el.addEventListener('touchend', finish);
		}

		// ── Open group (EXPLOSION) ─────────────────────────────────
		function openGroup(card) {
			sourceCard = card;
			sourceRect = card.getBoundingClientRect();
			const images = card.dataset.images.split(',').filter(Boolean);
			if (images.length === 0) return;

			const count  = images.length;
			const label  = card.dataset.label;

			const isMobile = window.innerWidth < 768;
			const cardW = count === 1 ? (isMobile ? 280 : 500)
			            : count <= 3  ? (isMobile ? 200 : 350)
			            : count <= 6  ? (isMobile ? 160 : 260)
			            :               (isMobile ? 130 : 200);
			const cardH = Math.round(cardW * 1.25); // more portrait aspect for images
			
			explodeCanvas.innerHTML = '';
			activeCards = [];

			// Layout
			const canvasW = window.innerWidth;
			const canvasH = window.innerHeight - HEADER_H;
			const gap   = isMobile ? 14 : 36;
			const cellW = cardW + gap;
			const cellH = cardH + gap;
			const cols  = Math.max(1, Math.floor(canvasW / cellW));
			const rows  = Math.max(1, Math.floor(canvasH / cellH));
			const offsetX = (canvasW - (cols * cellW - gap)) / 2;
			const offsetY = (canvasH - (rows * cellH - gap)) / 2;

			let slots = [];
			for (let r = 0; r < rows; r++)
				for (let c = 0; c < cols; c++)
					slots.push({ r, c });
			slots.sort(() => Math.random() - 0.5);

			const srcCX = sourceRect.left + sourceRect.width  / 2;
			const srcCY = sourceRect.top  + sourceRect.height / 2 - HEADER_H;

			overlay.classList.add('open');
			document.body.style.overflow = 'hidden';

			images.forEach((src, i) => {
				const slot = slots[i % slots.length];
				const jx   = (Math.random() - 0.5) * gap * 0.6;
				const jy   = (Math.random() - 0.5) * gap * 0.6;
				const finalL = offsetX + slot.c * cellW + jx;
				const finalT = offsetY + slot.r * cellH + jy;
				const finalCX = finalL + cardW / 2;
				const finalCY = finalT + cardH / 2;
				const rot = (Math.random() - 0.5) * 16;

				const cardEl = document.createElement('div');
				cardEl.className = 'explode-item-card';
				Object.assign(cardEl.style, {
					position: 'absolute',
					left: finalL + 'px',
					top:  finalT + 'px',
					width:  cardW + 'px',
					height: cardH + 'px',
					borderRadius: Math.round(cardW * 0.05) + 'px',
					overflow: 'hidden',
					border:   '2px solid rgba(255,255,255,0.15)',
					boxShadow:'0 4px 18px rgba(0,0,0,0.65)',
					cursor:   'grab',
					userSelect:'none',
					zIndex:   String(10 + i),
				});

				const img = document.createElement('img');
				Object.assign(img.style, {
					width:'100%', height:'100%', objectFit:'contain',
					display:'block', pointerEvents:'none', backgroundColor: '#000'
				});
				img.src = src;
				cardEl.appendChild(img);
				explodeCanvas.appendChild(cardEl);
				activeCards.push({ el: cardEl, cardW, cardH });

				gsap.set(cardEl, {
					opacity:  0,
					scale:    0.05,
					rotation: 0,
					x: srcCX - finalCX,
					y: srcCY - finalCY,
				});

				gsap.to(cardEl, {
					opacity:  1,
					scale:    1,
					rotation: rot,
					x: 0,
					y: 0,
					duration: 0.75,
					delay:    i * 0.07,
					ease:     'back.out(1.6)',
					onComplete: () => makeDraggable(cardEl),
				});

				cardEl.addEventListener('click', () => {
					if (!cardEl._wasMoved) openLightbox(src);
					cardEl._wasMoved = false;
				});
			});

			explodeTitle.textContent = label + ' Transformations';
			sourceCard.classList.add('active');
		}

		// ── Compact (implosion back to pile) ───────────────────────
		function closeGroup() {
			if (!activeCards.length || !sourceRect) return;

			const destCX = sourceRect.left + sourceRect.width  / 2;
			const destCY = sourceRect.top  + sourceRect.height / 2 - HEADER_H;

			activeCards.forEach(({ el, cardW, cardH }, i) => {
				const r    = el.getBoundingClientRect();
				const curCX = r.left + cardW / 2;
				const curCY = r.top  + cardH / 2 - HEADER_H;

				gsap.to(el, {
					x: gsap.getProperty(el, 'x') + (destCX - curCX),
					y: gsap.getProperty(el, 'y') + (destCY - curCY),
					scale:    0.05,
					opacity:  0,
					rotation: 0,
					duration: 0.5,
					delay:    i * 0.03,
					ease:     'power3.in',
				});
			});

			const totalMs = activeCards.length * 30 + 600;
			setTimeout(() => {
				overlay.classList.remove('open');
				document.body.style.overflow = '';
				setTimeout(() => {
					explodeCanvas.innerHTML = '';
					activeCards = [];
					if (sourceCard) sourceCard.classList.remove('active');
					sourceCard = null;
					sourceRect = null;
				}, 400);
			}, totalMs);
		}

		// ── Lightbox ───────────────────────────────────────────────
		const lightbox    = document.getElementById('explode-lightbox');
		const lightboxImg = document.getElementById('explode-lightbox-img');
		function openLightbox(src) { lightboxImg.src = src; lightbox.classList.add('open'); }
		function closeLightbox() {
			lightbox.classList.remove('open');
			setTimeout(() => { lightboxImg.src = ''; }, 300);
		}
		lightbox.addEventListener('click', closeLightbox);

		// ── Attach all handlers ─────────────────────────────────────
		groupCards.forEach(card => card.addEventListener('click', () => openGroup(card)));
		if (compactBtn) compactBtn.addEventListener('click', closeGroup);
		document.addEventListener('keydown', e => {
			if (e.key === 'Escape') {
				if (lightbox.classList.contains('open')) closeLightbox();
				else if (overlay.classList.contains('open')) closeGroup();
			}
		});

		}); // end import('gsap')
    });
</script>
